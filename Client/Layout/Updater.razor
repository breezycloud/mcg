
@inject HttpClient Http
@implements IDisposable
@using Shared.Helpers

<UpdateModal ServerVersion="@serverVersion" ClientVersion="@clientVersion" ReleaseNotes="@releaseNotes" />
@code {
    private string clientVersion = string.Empty;
    private string serverVersion = string.Empty;
    private bool forceUpdate;
    private string? releaseNotes;
    private Timer? versionCheckTimer;

    [CascadingParameter]
    public Task<AuthenticationState> authenticationState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await CheckForUpdates();

        // Check every 15 minutes
        versionCheckTimer = new Timer(async _ =>
        {
            await CheckForUpdates();
            StateHasChanged();
        }, null, TimeSpan.FromMinutes(15), TimeSpan.FromMinutes(15));
    }

    private async Task CheckForUpdates()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<VersionManifest>("appversion");
            if (response is null) return;

            serverVersion = response.AppVersion;
            forceUpdate = response.ForceUpdate;
            releaseNotes = response.ReleaseNotes;

            var localClientVersion = await localStorage.GetItemAsync<string>("clientVersion");
            if (string.IsNullOrEmpty(localClientVersion))
            {
                // Nothing to update FROM — this browser has never recorded a version before
                // (first-ever visit). Just remember the current one; don't prompt.
                await localStorage.SetItemAsync("clientVersion", serverVersion);
                return;
            }

            clientVersion = localClientVersion;

            // version.txt is a fixed-width "yyyyMMddHHmmss" timestamp, so ordinal string
            // comparison sorts chronologically — this only prompts when the server is
            // genuinely newer, not just different.
            if (string.CompareOrdinal(serverVersion, clientVersion) <= 0)
                return;

            if (forceUpdate)
            {
                var userAuthenticationState = await authenticationState;
                if (userAuthenticationState.User?.Identity?.IsAuthenticated == true)
                    AppState.ShowUpdateDialog = true;
                return;
            }

            // Check if user previously deferred this version
            var lastDeferredVersion = await localStorage.GetItemAsync<string>("lastDeferredVersion");
            if (lastDeferredVersion != serverVersion)
            {
                var userAuthenticationState = await authenticationState;
                if (userAuthenticationState.User?.Identity?.IsAuthenticated == true)
                    AppState.ShowUpdateDialog = true;
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Version check failed: {ex.Message}");
        }
    }

    public void Dispose()
    {
        versionCheckTimer?.Dispose();
    }
}
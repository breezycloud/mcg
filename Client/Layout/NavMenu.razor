    [CascadingParameter] public Task<AuthenticationState>? AuthenticationState { get; set; }

    private HashSet<string> userRoles = [];
    private string OpenDropdown { get; set; } = string.Empty;

    private bool ShowOverview => OverviewRoles.Any(userRoles.Contains);

    private IEnumerable<(NavGroup Group, List<NavLink> Links)> VisibleGroups =>
        Groups
            .Select(g => (Group: g, Links: g.Links.Where(l => l.Roles.Any(userRoles.Contains)).ToList()))
            .Where(g => g.Links.Count > 0);

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationState is not null)
        {
            var authState = await AuthenticationState;
            userRoles = authState.User.Claims
                .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                .Select(c => c.Value)
                .ToHashSet();
        }

        // Load the initial pending-review count into the shared AppState singleton.
        // Non-manager roles return 0 silently from the API — no error thrown.
        AppState.DailyReportBadgeCount = await DailyReportService.GetPendingReviewCountAsync(default);

        // Subscribe to AppState change so the badge re-renders without extra HTTP calls
        AppState.DailyReportBadgeChanged += OnBadgeChanged;
        // Subscribe to SignalR events
        AppHubService.OnReportSubmitted += OnReportSubmittedIncrementBadge;
    }

    public void Dispose()
    {
        AppState.DailyReportBadgeChanged -= OnBadgeChanged;
        AppHubService.OnReportSubmitted -= OnReportSubmittedIncrementBadge;
    }

    private void OnBadgeChanged(object? sender, EventArgs e)
        => InvokeAsync(StateHasChanged);

    private void OnReportSubmittedIncrementBadge(string reportNo, Guid reportId)
    {
        // A team member submitted — increment the pending review count for managers.
        // The setter fires DailyReportBadgeChanged which triggers StateHasChanged above.
        InvokeAsync(() =>
        {
            AppState.DailyReportBadgeCount++;
            return Task.CompletedTask;
        });
    }

    private void ToggleDropdown(string dropdown)
    {
        if (OpenDropdown == dropdown)
        {
            OpenDropdown = string.Empty;
        }
        else
        {
            OpenDropdown = dropdown;
        }
    }

    private void CloseDropdown()
    {
        OpenDropdown = string.Empty;
    }

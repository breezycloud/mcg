<ul class="space-y-2">
    @if (ShowOverview)
    {
        <li>
            <a href="/dashboard" class="flex items-center p-2 text-base font-medium text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group">
                <!-- Overview Icon -->
                <svg aria-hidden="true" class="w-6 h-6 text-gray-500 transition duration-75 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"></path>
                    <path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"></path>
                </svg>
                <span class="ml-3">Overview</span>
            </a>
        </li>
    }

    @foreach (var (group, links) in VisibleGroups)
    {
        <button type="button"
                class="flex items-center p-2 w-full text-base font-medium text-gray-900 rounded-lg transition duration-75 group hover:bg-gray-100 dark:text-white dark:hover:bg-gray-700"
                @onclick="@(() => ToggleDropdown(group.Key))"
                aria-controls="dropdown-@group.Key"
                aria-expanded="@(OpenDropdown == group.Key)">
            @((MarkupString)group.IconSvg)
            <span class="flex-1 ml-3 text-left whitespace-nowrap">@group.Label</span>
            <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
        </button>
        <ul id="dropdown-@group.Key" class="py-2 space-y-2 @(OpenDropdown == group.Key ? "" : "hidden")">
            @foreach (var link in links)
            {
                <li>
                    <a href="@link.Href" @onclick="CloseDropdown" class="flex items-center p-2 pl-11 w-full text-base font-medium text-gray-900 rounded-lg transition duration-75 group hover:bg-gray-100 dark:text-white dark:hover:bg-gray-700">
                        @((MarkupString)link.IconSvg)
                        @link.Label
                    </a>
                </li>
            }
        </ul>
    }

    <!-- Daily Reports — visible to all authenticated users, badge for managers -->
    <AuthorizeView>
        <Authorized>
            <li>
                <a href="/daily-reports"
                   class="flex items-center p-2 text-base font-medium text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group">
                    <!-- Daily Report Icon -->
                    <svg aria-hidden="true" class="w-6 h-6 text-gray-500 transition duration-75 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm4 18H6V4h7v5h5v11zM8 15h8v2H8v-2zm0-4h8v2H8v-2z"/>
                    </svg>
                    <span class="ml-3 flex-1">Daily Reports</span>
                    @if (AppState.DailyReportBadgeCount > 0)
                    {
                        <span class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-red-500 rounded-full"
                              title="@AppState.DailyReportBadgeCount unreviewed submitted report(s)">
                            @(AppState.DailyReportBadgeCount > 99 ? "99+" : AppState.DailyReportBadgeCount.ToString())
                        </span>
                    }
                </a>
            </li>
        </Authorized>
    </AuthorizeView>
</ul>


@inject IDailyReportService DailyReportService
@inject AppHubService AppHubService
@implements IDisposable


@inject IAuthService AuthService
@inject IUserService UserService
@implements IDisposable

<div class="flex items-center gap-2 mx-3">
    @if (CurrentUser is not null)
    {
        <span class="hidden sm:inline text-sm font-medium text-gray-700 dark:text-gray-200 whitespace-nowrap">
            Hello, @CurrentUser.FirstName <span aria-hidden="true">👋</span>
        </span>
    }

    <button
      type="button"
      class="flex text-sm rounded-full focus:ring-4 focus:ring-gray-300 dark:focus:ring-gray-600"
      id="user-menu-button"
      aria-expanded="false"
      data-dropdown-toggle="dropdown"
    >
      <span class="sr-only">Open user menu</span>
      @if (!string.IsNullOrEmpty(AvatarUrl))
      {
          <img class="w-8 h-8 rounded-full object-cover" src="@AvatarUrl" alt="Your avatar" />
      }
      else
      {
          <span class="w-8 h-8 rounded-full flex items-center justify-center bg-blue-600 text-white text-xs font-semibold">
              @Initials
          </span>
      }
    </button>
</div>

  <div
    class="hidden z-50 my-4 w-56 text-base list-none bg-white rounded divide-y divide-gray-100 shadow dark:bg-gray-700 dark:divide-gray-600 rounded-xl"
    id="dropdown">
    <AuthorizeView Context="auth">
    <div class="py-3 px-4">
      <span
        class="block text-sm font-semibold text-gray-900 dark:text-white"
        >@auth.User.Identity?.Name</span>
      <span
        class="block text-sm text-gray-900 truncate dark:text-white">@(CurrentUser?.Email)</span>
    </div>
    <ul
      class="py-1 text-gray-700 dark:text-gray-300"
      aria-labelledby="dropdown">
      <li>
        <a
          href="/my-account/@id"
          class="block py-2 px-4 text-sm hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-400 dark:hover:text-white"
          >My profile</a>
      </li>
      @* <li>
        <a
          href="#"
          class="block py-2 px-4 text-sm hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-400 dark:hover:text-white"
          >Account settings</a>
      </li> *@
    </ul>
    <ul
      class="py-1 text-gray-700 dark:text-gray-300"
      aria-labelledby="dropdown">
      <li>
        <a
          @onclick="LogOut"
          class="block py-2 px-4 text-sm hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white"
          >Sign out</a>
      </li>
    </ul>
    </AuthorizeView>
  </div>



@code {

  private Guid id { get; set; }
  private User? CurrentUser { get; set; }
  private string? _token;

  private string? AvatarUrl => CurrentUser?.Avatar?.PreviewUrl is { } url
      ? WithToken(url)
      : null;

  private string Initials => CurrentUser is null
      ? "?"
      : $"{CurrentUser.FirstName?.ElementAtOrDefault(0)}{CurrentUser.LastName?.ElementAtOrDefault(0)}".ToUpperInvariant();

  protected override async Task OnInitializedAsync()
  {
    id = await localStorage.GetItemAsync<Guid>("uid");
    _token = await CustomAuthenticationProvider.GetTokenAsync();
    await LoadCurrentUserAsync();

    AppState.CurrentUserProfileChanged += OnCurrentUserProfileChanged;

    await base.OnInitializedAsync();
  }

  private async Task LoadCurrentUserAsync()
  {
    if (id == Guid.Empty) return;
    try
    {
        CurrentUser = await UserService.GetAsync(id, CancellationToken.None);
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error loading current user for header: {ex.Message}");
    }
  }

  private async void OnCurrentUserProfileChanged(object? sender, EventArgs e)
  {
    await LoadCurrentUserAsync();
    await InvokeAsync(StateHasChanged);
  }

  // Same auth workaround as FileListView/FilePreviewModal: a plain <img> src can't carry an
  // Authorization header, so the token rides along as a query param instead.
  private string? WithToken(string? url)
  {
    if (string.IsNullOrEmpty(url) || string.IsNullOrEmpty(_token)) return url;
    var separator = url.Contains('?') ? '&' : '?';
    return $"{url}{separator}access_token={Uri.EscapeDataString(_token)}";
  }

  private async Task LogOut()
  {
    var refreshToken = await localStorage.GetItemAsync<string>("refreshToken");
    if (!string.IsNullOrWhiteSpace(refreshToken))
    {
        // Best-effort: revokes the refresh token server-side so it can't be used again even if
        // it leaked (e.g. a shared/public machine) — previously logout only cleared local
        // storage, leaving a 30-day-valid refresh token sitting unrevoked on the server.
        await AuthService.Logout(refreshToken, CancellationToken.None);
    }

    await localStorage.RemoveItemAsync("uid");
    await localStorage.RemoveItemAsync("token");
    await localStorage.RemoveItemAsync("refreshToken");
    await localStorage.RemoveItemAsync("shopId");
    nav.NavigateTo("/", true);
  }

  public void Dispose()
  {
    AppState.CurrentUserProfileChanged -= OnCurrentUserProfileChanged;
  }
}

@using Shared.Models.Checkpoints
@using Client.Pages.Modals

<div class="@(Compact ? "py-3 first:pt-0 last:pb-0" : "p-6 bg-white border border-gray-200 rounded-xl shadow-sm dark:bg-gray-800 dark:border-gray-700")
            @(!Compact && Data.IsSiding ? "border-yellow-300 bg-yellow-50/50 dark:bg-yellow-900/10" : "")">

    <!-- Header -->
    <div class="flex justify-between items-start @(Compact ? "mb-2" : "mb-4")">
        <div class="flex-1 flex items-center gap-2 flex-wrap">
            <h5 class="@(Compact ? "text-base" : "text-xl") font-bold text-gray-900 dark:text-white">
                @Data.Station?.Name
            </h5>

            @if (Compact && Data.IsSiding && Data.SidingHours > 0)
            {
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                    SIDING @Data.SidingHours.ToString("0.0")h
                </span>
            }

            @if (Data.InvoicedStationId.HasValue && Data.StationId != Data.InvoicedStationId && Data.InvoicedStation != null)
            {
                <p class="@(Compact ? "text-xs w-full" : "text-sm mt-1") text-gray-500 dark:text-gray-400">
                    💰 Invoiced: @Data.InvoicedStation.Name
                </p>
            }
        </div>

        @if (AllowInlineEdit && !isEditing)
        {
            <button type="button" @onclick="ToggleEdit" aria-label="Edit discharge"
                    class="p-1.5 text-blue-600 hover:text-blue-800 dark:text-blue-400 flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
            </button>
        }
        @if (ShowDeleteButton)
        {
            <button type="button" aria-label="Delete discharge"
                    class="inline-flex items-center p-2 text-sm font-medium text-red-700 bg-white border border-red-700 rounded-lg hover:bg-red-700 hover:text-white"
                    @onclick="() => deleteModal.Show()">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        }
    </div>

    <!-- Siding Badge -->
    @if (!Compact && Data.IsSiding && Data.SidingHours > 0)
    {
        <div class="mb-4 inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                    bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
            </svg>
            SIDING: @Data.SidingHours.ToString("0.0")h
        </div>
    }

    @if (isEditing)
    {
        <!-- EDIT MODE -->
        <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label for="@($"{_instanceId}-arrival")" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Arrival</label>
                    <input id="@($"{_instanceId}-arrival")" type="datetime-local" @bind="editData.TruckArrival"
                           @bind:format="yyyy-MM-ddTHH:mm"
                           class="w-full p-2 border rounded dark:bg-gray-700 dark:text-white"/>
                </div>
                <div>
                    <label for="@($"{_instanceId}-start")" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start Time</label>
                    <input id="@($"{_instanceId}-start")" type="datetime-local" @bind="editData.DischargeStartTime"
                           @bind:format="yyyy-MM-ddTHH:mm"
                           class="w-full p-2 border rounded dark:bg-gray-700 dark:text-white"/>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label for="@($"{_instanceId}-qty")" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Quantity</label>
                    <input id="@($"{_instanceId}-qty")" type="number" step="0.01" @bind="editData.QuantityDischarged"
                           class="w-full p-2 border rounded dark:bg-gray-700 dark:text-white"/>
                </div>
                <div class="flex items-center">
                    <input type="checkbox" id="@($"{_instanceId}-final")" @bind="editData.IsFinalDischarge" class="mr-2"/>
                    <label for="@($"{_instanceId}-final")" class="text-sm font-medium">Final Discharge</label>
                </div>
            </div>

            <div class="flex justify-end space-x-2 pt-2">
                <button type="button" @onclick="CancelEdit" class="px-3 py-1 text-sm text-gray-600 rounded">Cancel</button>
                <button type="button" @onclick="SaveEdit" class="px-3 py-1 text-sm bg-blue-600 text-white rounded">Save</button>
            </div>
        </div>
    }
    else
    {
        <!-- VIEW MODE -->
        @if (Compact)
        {
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-4 gap-y-3 text-sm">
                <div>
                    <div class="text-[11px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">Arrival</div>
                    <div class="font-medium text-gray-900 dark:text-gray-100">@(Data.TruckArrival?.ToString("dd MMM HH:mm") ?? "—")</div>
                </div>
                <div>
                    <div class="text-[11px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">Start</div>
                    <div class="font-medium text-gray-900 dark:text-gray-100">@(Data.DischargeStartTime?.ToString("dd MMM HH:mm") ?? "—")</div>
                </div>
                <div>
                    <div class="text-[11px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">Quantity</div>
                    <div class="font-medium text-gray-900 dark:text-gray-100">@Data.QuantityDischarged.ToString("N0") MT</div>
                </div>
                <div>
                    <div class="text-[11px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">Final</div>
                    <div class="font-medium @(Data.IsFinalDischarge ? "text-emerald-600 dark:text-emerald-400" : "text-gray-500 dark:text-gray-400")">@(Data.IsFinalDischarge ? "Yes" : "No")</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Data.Notes))
            {
                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 italic">@Data.Notes</p>
            }

            @if (Data.Files != null && Data.Files.Any())
            {
                <div class="mt-2 flex flex-wrap gap-1.5">
                    @foreach (var file in Data.Files)
                    {
                        <FileChip File="file" OnPreview="(f) => filePreview.Show(f)" />
                    }
                </div>
            }
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <span class="text-gray-500 dark:text-gray-400">Arrival</span>
                    <p class="font-medium">@(Data.TruckArrival?.ToString("dd MMM HH:mm") ?? "—")</p>
                </div>
                <div>
                    <span class="text-gray-500 dark:text-gray-400">Start</span>
                    <p class="font-medium">@(Data.DischargeStartTime?.ToString("dd MMM HH:mm") ?? "—")</p>
                </div>
                <div>
                    <span class="text-gray-500 dark:text-gray-400">Quantity</span>
                    <p class="font-medium">@Data.QuantityDischarged.ToString("0.##") MT</p>
                </div>
                <div>
                    <span class="text-gray-500 dark:text-gray-400">Final</span>
                    <p class="font-medium">@(Data.IsFinalDischarge ? "✅ Yes" : "⏳ No")</p>
                </div>
                <div>
                    <span class="text-gray-500 dark:text-gray-400">Files</span>
                    <p class="font-medium">@Data.Files.Count</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Data.Notes))
            {
                <div class="mt-4 p-3 bg-gray-50 dark:bg-gray-700 rounded">
                    <p class="text-sm text-gray-700 dark:text-gray-300">@Data.Notes</p>
                </div>
            }

            @if (ShowUpload)
            {
                <div class="mt-4">
                    <FileUploadView OnFilesUploaded="HandleFilesUploaded" />
                </div>
            }

            @if (Data.Files != null && Data.Files.Any())
            {
                <div class="mt-4">
                    <FileListView Files="Data.Files" ShowDelete="@ShowFileDelete" OnDelete="HandleFileDelete" />
                </div>
            }
        }
    }
</div>

<ConfirmationModal @ref="deleteModal" Title="Delete Discharge"
                    Message="Are you sure you want to delete this discharge record? This action cannot be undone."
                    OnClose="HandleDeleteModalClose" />

<FilePreviewModal @ref="filePreview" />

@code {
    [Parameter] public Discharge Data { get; set; } = new();
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }
    [Parameter] public EventCallback<Discharge> OnEdit { get; set; }

    // Trip detail view: staff can correct discharge details inline, but not delete from there.
    [Parameter] public bool AllowInlineEdit { get; set; } = false;

    // Dense variant: smaller header/grid, and attached files render as clickable preview
    // chips instead of the full FileListView block.
    [Parameter] public bool Compact { get; set; } = false;

    // Standalone Discharges view: staff can delete and attach supporting documents, but there's
    // no inline-edit affordance there today.
    [Parameter] public bool ShowDeleteButton { get; set; } = false;
    [Parameter] public bool ShowUpload { get; set; } = false;
    [Parameter] public bool ShowFileDelete { get; set; } = false;
    [Parameter] public EventCallback<List<UploadResult>> OnFilesUploaded { get; set; }
    [Parameter] public EventCallback<UploadResult> OnFileDelete { get; set; }

    private readonly string _instanceId = Guid.NewGuid().ToString("N");
    private bool isEditing = false;
    private Discharge editData = new();
    private ConfirmationModal deleteModal = default!;
    private FilePreviewModal filePreview = default!;

    protected override void OnParametersSet()
    {
        editData = new Discharge
        {
            Id = Data.Id,
            TruckArrival = Data.TruckArrival,
            DischargeStartTime = Data.DischargeStartTime,
            QuantityDischarged = Data.QuantityDischarged,
            IsFinalDischarge = Data.IsFinalDischarge,
            StationId = Data.StationId,
            InvoicedStationId = Data.InvoicedStationId,
            Notes = Data.Notes
        };
    }

    private void ToggleEdit() => isEditing = true;

    private void CancelEdit()
    {
        isEditing = false;
        editData = new Discharge
        {
            TruckArrival = Data.TruckArrival,
            DischargeStartTime = Data.DischargeStartTime,
            QuantityDischarged = Data.QuantityDischarged,
            IsFinalDischarge = Data.IsFinalDischarge
        };
    }

    private async Task SaveEdit()
    {
        Data.TruckArrival = editData.TruckArrival;
        Data.DischargeStartTime = editData.DischargeStartTime;
        Data.QuantityDischarged = editData.QuantityDischarged;
        Data.IsFinalDischarge = editData.IsFinalDischarge;
        Data.Notes = editData.Notes;

        // Recalculate Siding
        if (Data.TruckArrival.HasValue && Data.DischargeStartTime.HasValue)
        {
            var hours = (Data.DischargeStartTime.Value - Data.TruckArrival.Value).TotalHours;
            Data.IsSiding = hours > 0 && hours <= 24;
            Data.SidingHours = Math.Max(0, hours);
        }

        isEditing = false;
        await OnEdit.InvokeAsync(Data);
    }

    private async Task HandleDeleteModalClose(bool confirmed)
    {
        if (confirmed)
        {
            await OnDelete.InvokeAsync(Data.Id);
        }
    }

    private async Task HandleFilesUploaded(List<UploadResult> files)
    {
        // ShowUpload only renders on the standalone Discharges page (ViewDischarges.razor) —
        // anything uploaded through this uploader is the discharge's waybill.
        foreach (var file in files)
        {
            file.Category = FileCategories.Waybill;
        }

        Data.Files.AddRange(files);
        await OnFilesUploaded.InvokeAsync(files);
        StateHasChanged();
    }

    private async Task HandleFileDelete(UploadResult file)
    {
        Data.Files.Remove(file);
        await OnFileDelete.InvokeAsync(file);
        StateHasChanged();
    }
}

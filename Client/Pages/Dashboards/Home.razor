@page "/dashboard"
@using Client.Pages.Products
@inject IDashboardService DashboardService
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@implements IAsyncDisposable
@attribute [Authorize]

<div class="p-3 sm:p-3 space-y-6 bg-gray-50 dark:bg-gray-900">
    <!-- Header with SignalR status -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Dashboard</h1>
            <span class="text-sm @(isConnected ? "text-green-500" : "text-red-500")">
                @(isConnected ? "● Live" : "● Disconnected")
            </span>
        </div>
    </div>
    
    <!-- Time Filter -->
    <Filter OnFilterChanged="HandleTimeFilterChange" />
    <div class="flex flex-col md:flex-row justify-between items-center mb-4">
        <div class="w-full md:w-1/3">
            <ProductSelector OnProductSelected="HandleProductChanged" />
        </div>
    </div>
    <!-- Dashboard content -->
    <DashboardMetrics  StartDate="@filterStartDate" EndDate="@filterEndDate" Product="@selectedProduct" TimeFilter="@currentTimeFilter" />

    <!-- Charts & Recent Trips -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2">
            <TripStatusChart Product="@selectedProduct" />
        </div>
        <div class="lg:col-span-1">
            <RecentTrips StartDate="@filterStartDate" EndDate="@filterEndDate" Product="@selectedProduct"/>
        </div>
    </div>

    <ShortagesChart StartDate="@filterStartDate.Value" EndDate="@filterEndDate.Value" />

    <!-- Product Shipments Table -->
    <ProductShipments StartDate="@filterStartDate" EndDate="@filterEndDate" Product="@selectedProduct" TimeFilter="@currentTimeFilter" />
</div>

@code {
    private HubConnection? hubConnection;
    private bool isConnected;
    private DateOnly? filterStartDate;
    private DateOnly? filterEndDate;
    private TimeFilter currentTimeFilter = TimeFilter.ThisWeek;
    private ProductFilter selectedProduct;

    protected override async Task OnInitializedAsync()
    {
        filterStartDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek));
        filterEndDate = DateOnly.FromDateTime(DateTime.Today);
        await InitializeSignalR();
    }

    private void HandleProductChanged(ProductFilter product)
    {
        selectedProduct = product;
        AppState.OnFilterChanged();
    }

    private async Task InitializeSignalR()
    {
        // The hub is mapped on the Api, not the Client, so resolve against the
        // same Api base address the rest of the app uses (they run on different
        // origins outside of combined hosting).
        var apiBaseAddress = new Client.Handlers.Constants(NavigationManager, Configuration).BaseAddress();
        var hubUrl = new Uri(new Uri(apiBaseAddress), "/hubs/dashboard");

        hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string>("DashboardDataChanged", entityType =>
        {
            // Debounced in AppState — each subscribed component decides whether the changed
            // entity type is relevant to it before re-fetching its own data.
            AppState.OnDashboardDataChanged(entityType);
        });

        // Without these, isConnected was set once after the first successful connect and never
        // re-evaluated — a dropped connection (server restart, idle timeout) left the "● Live"
        // badge showing green forever while every widget silently stopped receiving updates.
        hubConnection.Reconnected += _ => { isConnected = true; return InvokeAsync(StateHasChanged); };
        hubConnection.Reconnecting += _ => { isConnected = false; return InvokeAsync(StateHasChanged); };
        hubConnection.Closed += _ => { isConnected = false; return InvokeAsync(StateHasChanged); };

        try
        {
            await hubConnection.StartAsync();
            isConnected = true;
        }
        catch
        {
            isConnected = false;
        }
    }

    private void HandleTimeFilterChange((DateOnly Start, DateOnly End, TimeFilter Filter) dates)
    {
        AppState.IsBusy = true;
        filterStartDate = dates.Start;
        filterEndDate = dates.End;
        currentTimeFilter = dates.Filter;
        AppState.OnFilterChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

@using Shared.Extensions
@using Shared.Enums
@inject IDashboardService DashboardService
@implements IDisposable

@if (IsLoading)
{
    <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow mb-8">
        <div class="skeleton w-48 h-6 mb-4 rounded"></div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                    <tr>
                        <th class="px-6 py-3"><div class="skeleton w-20 h-4 rounded"></div></th>
                        <th class="px-6 py-3"><div class="skeleton w-20 h-4 rounded"></div></th>
                        <th class="px-6 py-3"><div class="skeleton w-20 h-4 rounded"></div></th>
                        <th class="px-6 py-3"><div class="skeleton w-20 h-4 rounded"></div></th>
                        <th class="px-6 py-3"><div class="skeleton w-20 h-4 rounded"></div></th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < 3; i++)
                    {
                        <tr class="skeleton-table-row">
                            <td class="skeleton-table-cell"><div class="skeleton w-32 h-5 rounded"></div></td>
                            <td class="skeleton-table-cell"><div class="skeleton w-24 h-5 rounded"></div></td>
                            <td class="skeleton-table-cell"><div class="skeleton w-28 h-5 rounded"></div></td>
                            <td class="skeleton-table-cell"><div class="skeleton w-20 h-5 rounded"></div></td>
                            <td class="skeleton-table-cell"><div class="skeleton w-16 h-5 rounded"></div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else    
{
    <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow mt-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Product Shipments</h3>
            <div class="flex items-center space-x-2">
                <span class="text-sm text-gray-500 dark:text-gray-400">@TimeRangeLabel</span>
                <button @onclick="ExportToExcel" 
                        class="px-3 py-1 text-xs bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded text-gray-800 dark:text-gray-200">
                    <i class="fas fa-download mr-1"></i> Export
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Product</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Trips</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Trend</th>
                    </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                    @if (shipments == null)
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-gray-700 dark:text-gray-200">Loading...</td>
                        </tr>
                    }
                    else
                    {                    
                        @foreach (var item in shipments)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-5 w-5 rounded-full @GetProductColorClass(item.Product)" style="@GetProductColorStyle(item.Product)"></div>
                                        <div class="ml-2 text-gray-900 dark:text-gray-100">@FormatProduct(item.Product)</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-gray-900 dark:text-gray-100">@item.TotalTrips</td>
                                <td class="px-6 py-4 whitespace-nowrap text-gray-900 dark:text-gray-100">
                                    @item.TotalQuantity.ToString("N1") @GetUnitForProduct(item.Product)
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="@GetTrendClass(item.Trend)">
                                        <i class="@GetTrendIcon(item.Trend) mr-1"></i>
                                        @item.Trend.ToString("N1")%
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
@code {
    [Parameter]
    public DateOnly? StartDate { get; set; }

    [Parameter]
    public DateOnly? EndDate { get; set; }
    [Parameter]
    public ProductFilter Product { get; set; } = ProductFilter.All;
    [Parameter]
    public TimeFilter TimeFilter { get; set; } = TimeFilter.ThisWeek;

    private List<ProductShipmentDto>? shipments;
    private string TimeRangeLabel => GetTimeRangeLabel();

    private bool IsLoading = false;

    protected override void OnInitialized()
    {
        AppState.DashboardDataChanged += OnDashboardDataChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async void OnDashboardDataChanged(object? sender, string entityType)
    {
        if (entityType == "Trip")
            await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        shipments = await DashboardService.GetProductShipmentsAsync(StartDate, EndDate, Product.ToString());
        IsLoading = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        AppState.DashboardDataChanged -= OnDashboardDataChanged;
    }

    private string GetTimeRangeLabel()
    {
        if (!StartDate.HasValue || !EndDate.HasValue)
            return "All Time";

        return TimeFilter switch
        {
            TimeFilter.ThisWeek => "This Week",
            TimeFilter.LastWeek => "Last Week",
            TimeFilter.ThisMonth => "This Month",
            TimeFilter.LastMonth => "Last Month",
            _ => $"{StartDate:MMM dd} - {EndDate:MMM dd}"
        };
    }


    private string GetProductColorClass(string? product)
    {
        if (string.IsNullOrWhiteSpace(product)) return "bg-gray-500";
        var p = product.Trim();
        return p switch
        {
            "PMS" => "bg-blue-500",
            "ATK" => "bg-black",
            "AGO" => "", // blue base + yellow top stripe applied via inline style instead
            "LPG" => "bg-blue-900",
            "CngLagos" or "CNG-Lagos" => "", // purple base + white top stripe applied via inline style instead
            "CNG" or "CngAbuja" or "CNG-Abuja" => "bg-purple-500",
            _ => "bg-gray-500"
        };
    }

    private string GetProductColorStyle(string? product)
    {
        var p = product?.Trim();
        return p switch
        {
            "AGO" => TopStripeGradient(baseColor: "#0ea5e9", stripeColor: "#eab308"),
            "CngLagos" or "CNG-Lagos" => TopStripeGradient(baseColor: "#a855f7", stripeColor: "#eab308"),
            _ => ""
        };
    }

    private static string TopStripeGradient(string baseColor, string stripeColor)
        => $"background: linear-gradient(to bottom, {stripeColor} 0%, {stripeColor} 30%, {baseColor} 30%, {baseColor} 100%);";

    private string GetUnitForProduct(string? product)
    {
        if (string.IsNullOrWhiteSpace(product)) return "LTR";
        var p = product.Trim();
        return p switch
        {
            "CNG" or "CngAbuja" or "CNG-Abuja" or "CngLagos" or "CNG-Lagos" => "SCM",
            "LPG" => "KG",
            _ => "LTR"
        };
    }

    private string FormatProduct(string? product)
    {
        if (string.IsNullOrWhiteSpace(product)) return "N/A";
        return product switch
        {
            "CNG" or "CngAbuja" => "CNG-Abuja",
            "CngLagos" => "CNG-Lagos",
            "CNG-Abuja" => "CNG-Abuja",
            "CNG-Lagos" => "CNG-Lagos",
            _ => product
        };
    }

    private string GetTrendClass(decimal trend)
    {
        return trend >= 0 ? "text-green-500" : "text-red-500";
    }

    private string GetTrendIcon(decimal trend)
    {
        return trend >= 0 ? "fas fa-arrow-up" : "fas fa-arrow-down";
    }

    private async Task ExportToExcel()
    {
        // Implementation would use EPPlus or similar
        // to generate an Excel file for download
    }
}
@page "/stations/report"
@inject IStationService StationService
@inject ITripService TripService
@attribute [Authorize(Roles = "Admin, Master, Supervisor")]
<PageTitle>Station Report</PageTitle>

<div class="px-4 lg:px-12 py-6">
    <div class="bg-white dark:bg-gray-800 relative shadow-md sm:rounded-lg overflow-hidden p-6">
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white">Station Report</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Pick a station to see all trips delivered there.</p>
            </div>
            <button type="button" @onclick="GoToStations"
                class="px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600">
                Back to Stations
            </button>
        </div>

        <!-- Filters -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Station</label>
                <Autocomplete TItem="Station"
                    SearchFunc="SearchStations"
                    SelectedChanged="OnStationSelected"
                    Placeholder="Search station by name..."
                    InitialText="@selectedStationName">
                    <OptionTemplate Context="station">
                        <span>@station.Name</span>
                    </OptionTemplate>
                </Autocomplete>
            </div>
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">From (optional)</label>
                <InputDate @bind-Value="startDate" @bind-Value:after="LoadReport"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"/>
            </div>
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">To (optional)</label>
                <InputDate @bind-Value="endDate" @bind-Value:after="LoadReport"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"/>
            </div>
        </div>

        @if (selectedStationId is null)
        {
            <div class="text-center py-10 text-gray-500 dark:text-gray-400">
                Search for and select a station above to see its report.
            </div>
        }
        else if (isLoading)
        {
            <div class="flex items-center gap-2 text-gray-500 py-10 justify-center">
                <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                </svg>
                Loading report...
            </div>
        }
        else
        {
            <!-- Tabs -->
            <div class="border-b border-gray-200 dark:border-gray-700 mb-4">
                <nav class="flex gap-6 -mb-px">
                    <button type="button" @onclick='() => activeTab = "all"'
                        class="py-3 px-1 border-b-2 text-sm font-medium @(activeTab == "all" ? "border-blue-600 text-blue-600 dark:text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")">
                        All Trips (@allRows.Count)
                    </button>
                    <button type="button" @onclick='() => activeTab = "complete"'
                        class="py-3 px-1 border-b-2 text-sm font-medium @(activeTab == "complete" ? "border-blue-600 text-blue-600 dark:text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")">
                        Complete Discharge (@completeRows.Count)
                    </button>
                    <button type="button" @onclick='() => activeTab = "shortage"'
                        class="py-3 px-1 border-b-2 text-sm font-medium @(activeTab == "shortage" ? "border-blue-600 text-blue-600 dark:text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")">
                        Shortage (@shortageRows.Count)
                    </button>
                </nav>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-100 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th class="px-4 py-2">Date</th>
                            <th class="px-4 py-2">Truck</th>
                            <th class="px-4 py-2">Product</th>
                            <th class="px-4 py-2">Driver</th>
                            <th class="px-4 py-2">Loading Depot</th>
                            <th class="px-4 py-2">Loading Date</th>
                            <th class="px-4 py-2 text-right">Dispatch Qty</th>
                            <th class="px-4 py-2 text-right">Discharged Qty</th>
                            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-900 dark:hover:text-white" @onclick="ToggleShortageSort">
                                <span class="inline-flex items-center gap-1">
                                    Shortage
                                    @if (shortageSort == SortDirection.Ascending)
                                    {
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" clip-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z"/></svg>
                                    }
                                    else if (shortageSort == SortDirection.Descending)
                                    {
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-3 h-3 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20"><path d="M10 3l4 4H6l4-4zm0 14l-4-4h8l-4 4z"/></svg>
                                    }
                                </span>
                            </th>
                            <th class="px-4 py-2">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ActiveRows.Count == 0)
                        {
                            <tr>
                                <td colspan="10" class="px-4 py-6 text-center text-gray-500 dark:text-gray-400">No trips found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in ActiveRows)
                            {
                                <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                                    <td class="px-4 py-2">@row.Date.ToString("dd MMM yyyy")</td>
                                    <td class="px-4 py-2">@row.TruckPlate <span class="text-xs text-gray-400">(@row.TruckNo)</span></td>
                                    <td class="px-4 py-2">@row.Product</td>
                                    <td class="px-4 py-2">@row.DriverName <span class="text-xs text-gray-400">(@row.DriverPhone)</span></td>
                                    <td class="px-4 py-2">@row.LoadingDepot</td>
                                    <td class="px-4 py-2">@row.LoadingDate</td>
                                    <td class="px-4 py-2 text-right">@row.DispatchQuantity.ToString("N1") @row.Unit</td>
                                    <td class="px-4 py-2 text-right">@row.DischargedQuantity.ToString("N1") @row.Unit</td>
                                    <td class="px-4 py-2 text-right @(row.ShortageAmount > 0 ? "text-red-600 dark:text-red-400 font-medium" : row.ShortageAmount < 0 ? "text-amber-600 dark:text-amber-400" : "")">
                                        @row.ShortageAmount.ToString("N1") @row.Unit
                                    </td>
                                    <td class="px-4 py-2">@row.Status</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private Guid? selectedStationId;
    private string? selectedStationName;
    private DateOnly? startDate;
    private DateOnly? endDate;
    private bool isLoading;
    private string activeTab = "all";

    private List<StationReportDto> allRows = [];
    private List<StationReportDto> completeRows = [];
    private List<StationReportDto> shortageRows = [];

    private enum SortDirection { None, Ascending, Descending }
    private SortDirection shortageSort = SortDirection.None;

    private List<StationReportDto> ActiveRows
    {
        get
        {
            var rows = activeTab switch
            {
                "complete" => completeRows,
                "shortage" => shortageRows,
                _ => allRows,
            };

            return shortageSort switch
            {
                SortDirection.Ascending => rows.OrderBy(r => r.ShortageAmount).ToList(),
                SortDirection.Descending => rows.OrderByDescending(r => r.ShortageAmount).ToList(),
                _ => rows,
            };
        }
    }

    private void ToggleShortageSort()
    {
        shortageSort = shortageSort switch
        {
            SortDirection.None => SortDirection.Descending,
            SortDirection.Descending => SortDirection.Ascending,
            _ => SortDirection.None,
        };
    }

    private async Task<List<Station>> SearchStations(string query, int page, CancellationToken ct)
    {
        var request = new GridDataRequest { SearchTerm = query, Page = page, PageSize = 10 };
        var response = await StationService.GetPagedAsync(request, ct);
        return response?.Data ?? [];
    }

    private async Task OnStationSelected(Station? station)
    {
        selectedStationId = station?.Id;
        selectedStationName = station?.Name;
        await LoadReport();
    }

    private async Task LoadReport()
    {
        if (!selectedStationId.HasValue)
        {
            return;
        }

        isLoading = true;
        StateHasChanged();
        try
        {
            var filter = new StationReportFilter
            {
                StationId = selectedStationId.Value,
                StartDate = startDate,
                EndDate = endDate,
            };
            allRows = await TripService.GetStationReportAsync(filter, AppState.GetCancellationToken());
            completeRows = allRows.Where(r => r.ShortageAmount == 0).ToList();
            shortageRows = allRows.Where(r => r.ShortageAmount > 50).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToStations()
    {
        nav.NavigateTo("stations");
    }
}

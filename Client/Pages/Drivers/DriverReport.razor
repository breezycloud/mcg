@* DriverReport.razor — Driver Performance Report *@
@page "/drivers/report"
@using System.Text
@using ApexCharts
@using Shared.Interfaces.Drivers
@using Shared.Models.Drivers
@inject IDriverReportService DriverReportService
@inject IExportService ExportService
@attribute [Authorize]

<div class="p-6 space-y-6">
    <!-- Header -->
    <div class="flex flex-wrap justify-between items-center gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Driver Performance Report</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Utilization, ratings, turnaround and license compliance across drivers</p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <div class="flex rounded-lg overflow-hidden border border-gray-300 dark:border-gray-600 text-sm">
                <button @onclick="@(() => SetPeriod(PeriodFilter.ThisMonth))"
                        class="px-3 py-2 font-medium @(Period == PeriodFilter.ThisMonth ? "bg-blue-600 text-white" : "bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600")">
                    This Month
                </button>
                <button @onclick="@(() => SetPeriod(PeriodFilter.AllTime))"
                        class="px-3 py-2 font-medium @(Period == PeriodFilter.AllTime ? "bg-blue-600 text-white" : "bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600")">
                    All Time
                </button>
            </div>

            <button @onclick="ExportToCsv" disabled="@IsExporting"
                    class="px-4 py-2.5 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 disabled:opacity-50 flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                @(IsExporting ? "Exporting..." : "Export CSV")
            </button>

            <button type="button" @onclick="() => GoToDrilldown()"
                class="px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600">
                Driver Drill-down
            </button>
        </div>
    </div>

    @if (IsLoading && Metrics is null)
    {
        <Loader />
    }
    else
    {
        <!-- North-star KPIs -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <MetricCard Label="Driver Utilization" Large="true" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.DriverUtilizationRate ?? 0)" Decimals="0" Suffix="%" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Avg Rating" Large="true" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.AvgRating ?? 0)" Decimals="1" Suffix="/5" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Avg Turnaround" Large="true" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.AvgTurnaroundDays ?? 0)" Decimals="1" Suffix="d" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Shortage Rate" Large="true" SubValue="@PeriodLabel"
                        Accent="@((Metrics?.ShortageRate ?? 0) > 20 ? "text-red-500" : "text-gray-900 dark:text-white")">
                <ValueContent>
                    <span class="inline-flex items-center gap-1">
                        <AnimatedNumber Value="@(Metrics?.ShortageRate ?? 0)" Decimals="1" Suffix="%" />
                        @if ((Metrics?.ShortageRate ?? 0) > 20)
                        {
                            <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <span class="sr-only">— above the 20% threshold</span>
                        }
                    </span>
                </ValueContent>
            </MetricCard>
        </div>

        <!-- Supporting KPIs -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
            <MetricCard Label="Total Drivers" Value="@(Metrics?.TotalDrivers.ToString() ?? "0")" />
            <MetricCard Label="On Trip" Value="@($"{Metrics?.OnTripCount}/{Metrics?.TotalDrivers}")" />
            <MetricCard Label="Trips" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.TripsInPeriod ?? 0)" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Licenses Expiring" Accent="@((Metrics?.LicensesExpiringSoon ?? 0) > 0 ? "text-orange-500" : "text-gray-900 dark:text-white")">
                <ValueContent><AnimatedNumber Value="@(Metrics?.LicensesExpiringSoon ?? 0)" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Expired Licenses" Accent="@((Metrics?.ExpiredLicenses ?? 0) > 0 ? "text-red-500" : "text-gray-900 dark:text-white")">
                <ValueContent><AnimatedNumber Value="@(Metrics?.ExpiredLicenses ?? 0)" /></ValueContent>
            </MetricCard>
        </div>

        <!-- License status breakdown + monthly trend -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">License Status Breakdown</h3>
                @if (LicenseStatusBreakdown.Count == 0)
                {
                    <p class="text-gray-500 dark:text-gray-400 text-sm">No drivers match this filter.</p>
                }
                <div class="@(LicenseStatusBreakdown.Count == 0 ? "hidden" : "")">
                    <ApexChart @ref="statusChart" TItem="LicenseStatusCount" Options="statusChartOptions" Height="300">
                        <ApexPointSeries TItem="LicenseStatusCount"
                                         Items="LicenseStatusBreakdown"
                                         SeriesType="SeriesType.Bar"
                                         Name="Drivers"
                                         XValue="@(e => e.Status)"
                                         YValue="@(e => (decimal)e.Count)"
                                         ShowDataLabels="true" />
                    </ApexChart>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">6-Month Trend</h3>
                @if (MonthlyTrend.Count == 0)
                {
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Not enough data yet.</p>
                }
                <div class="@(MonthlyTrend.Count == 0 ? "hidden" : "")">
                    <ApexChart @ref="trendChart" TItem="DriverMonthlyTrendDto" Options="trendChartOptions" Height="300">
                        <ApexPointSeries TItem="DriverMonthlyTrendDto"
                                         Items="MonthlyTrend"
                                         SeriesType="SeriesType.Bar"
                                         Name="Trips"
                                         XValue="@(e => e.Format)"
                                         YValue="@(e => (decimal)e.TripCount)" />
                        <ApexPointSeries TItem="DriverMonthlyTrendDto"
                                         Items="MonthlyTrend"
                                         SeriesType="SeriesType.Line"
                                         Name="Avg Rating"
                                         XValue="@(e => e.Format)"
                                         YValue="@(e => e.AvgRating)" />
                    </ApexChart>
                </div>
            </div>
        </div>

        <!-- Per-driver performance -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Driver Performance &middot; @PeriodLabel</h3>
                <span class="text-sm text-gray-500 dark:text-gray-400">@DriverPerformance.Count drivers &middot; click a row to drill in</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th class="px-4 py-3"></th>
                            <th class="px-4 py-3">Driver</th>
                            <th class="px-4 py-3">License</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3 text-center">Trips</th>
                            <th class="px-4 py-3 text-center">Avg Rating</th>
                            <th class="px-4 py-3 text-center">Shortage</th>
                            <th class="px-4 py-3 text-center">Avg Turnaround</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in DriverPerformance)
                        {
                            <tr @key="row.DriverId" @onclick="() => GoToDrilldown(row.DriverId)"
                                class="bg-white dark:bg-gray-800 border-b dark:border-gray-700 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 @(row.NeedsAttention ? "border-l-4 border-l-red-500" : "")">
                                <td class="px-2 text-center">
                                    @if (row.NeedsAttention)
                                    {
                                        <span title="Needs attention" class="text-red-500">&#9888;</span>
                                    }
                                </td>
                                <td class="px-4 py-3 font-medium text-gray-900 dark:text-white whitespace-nowrap">@row.FullName</td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 text-xs font-medium rounded-full @GetLicenseBadgeClass(row.LicenseStatus)">@row.LicenseStatus</span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 text-xs font-medium rounded-full @(row.CurrentStatus == "On Trip" ? "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300" : "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300")">@row.CurrentStatus</span>
                                </td>
                                <td class="px-4 py-3 text-center">@row.TripCount</td>
                                <td class="px-4 py-3 text-center">@row.AvgRating.ToString("F1")</td>
                                <td class="px-4 py-3 text-center @(row.ShortageRate > 20 ? "text-red-500 font-medium" : "")">@row.ShortageRate.ToString("F1")%</td>
                                <td class="px-4 py-3 text-center">@row.AvgTurnaroundDays.ToString("F1")d</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- License compliance -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">License Compliance &middot; expiring within 30 days</h3>
            @if (LicenseExpiry.Count == 0)
            {
                <p class="text-gray-500 dark:text-gray-400 text-sm">No licenses expiring or overdue.</p>
            }
            else
            {
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase border-b border-gray-200 dark:border-gray-700">
                        <tr>
                            <th class="py-2">Driver</th>
                            <th class="py-2">License No.</th>
                            <th class="py-2">Expiry Date</th>
                            <th class="py-2 text-center">Days</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in LicenseExpiry)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                                <td class="py-2 font-medium text-gray-900 dark:text-white">@entry.DriverName</td>
                                <td class="py-2">@entry.LicenseNumber</td>
                                <td class="py-2">@entry.ExpiryDate.ToString("dd MMM yyyy")</td>
                                <td class="py-2 text-center @(entry.DaysUntilExpiry < 0 ? "text-red-500 font-medium" : "text-orange-500")">
                                    @(entry.DaysUntilExpiry < 0 ? $"Overdue {-entry.DaysUntilExpiry}d" : $"{entry.DaysUntilExpiry}d")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@code {
    private record LicenseStatusCount(string Status, int Count);

    private enum PeriodFilter { ThisMonth, AllTime }

    private PeriodFilter Period = PeriodFilter.ThisMonth;

    private DriverFleetMetricsDto? Metrics;
    private List<DriverPerformanceRowDto> DriverPerformance = [];
    private List<DriverLicenseExpiryDto> LicenseExpiry = [];
    private List<DriverMonthlyTrendDto> MonthlyTrend = [];
    private List<LicenseStatusCount> LicenseStatusBreakdown = [];

    private bool IsLoading;
    private bool IsExporting;

    private ApexChart<LicenseStatusCount>? statusChart;
    private ApexChartOptions<LicenseStatusCount> statusChartOptions = new();

    private ApexChart<DriverMonthlyTrendDto>? trendChart;
    private ApexChartOptions<DriverMonthlyTrendDto> trendChartOptions = new();

    private string PeriodLabel => Period == PeriodFilter.ThisMonth ? "This Month" : "All Time";

    private DateOnly? StartDateParam => Period == PeriodFilter.ThisMonth
        ? new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1)
        : null;

    protected override async Task OnInitializedAsync()
    {
        statusChartOptions = new ApexChartOptions<LicenseStatusCount>
        {
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, Distributed = true, BorderRadius = 4 } },
            Legend = new Legend { Show = false },
            Grid = new Grid { StrokeDashArray = 4 },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Colors = ["#22c55e", "#f59e0b", "#ef4444", "#64748b"]
        };

        trendChartOptions = new ApexChartOptions<DriverMonthlyTrendDto>
        {
            Colors = ["#3b82f6", "#ef4444"],
            Grid = new Grid { StrokeDashArray = 4 },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Yaxis = [new YAxis { Labels = new YAxisLabels { Formatter = "function (v) { return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }" } }]
        };

        await LoadDataAsync();
    }

    private async Task SetPeriod(PeriodFilter period)
    {
        if (Period == period)
            return;

        Period = period;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var startDate = StartDateParam;

            var metricsTask = DriverReportService.GetMetricsAsync(startDate);
            var performanceTask = DriverReportService.GetDriverPerformanceAsync(startDate);
            var expiryTask = DriverReportService.GetLicenseExpiryAsync();
            var trendTask = DriverReportService.GetMonthlyTrendAsync(6);

            await Task.WhenAll(metricsTask, performanceTask, expiryTask, trendTask);

            Metrics = await metricsTask;
            DriverPerformance = await performanceTask;
            LicenseExpiry = await expiryTask;
            MonthlyTrend = await trendTask;

            LicenseStatusBreakdown = DriverPerformance
                .GroupBy(r => r.LicenseStatus)
                .Select(g => new LicenseStatusCount(g.Key, g.Count()))
                .OrderByDescending(x => x.Count)
                .ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to load driver report: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            // Render first so the ApexPointSeries children pick up the new Items via their
            // parameter binding before we ask the charts to re-pull their series — calling
            // UpdateSeriesAsync() before this render would push each chart's *previous* series.
            await InvokeAsync(StateHasChanged);

            if (LicenseStatusBreakdown.Count > 0 && statusChart is not null)
            {
                await statusChart.UpdateOptionsAsync(true, true, true);
                await statusChart.UpdateSeriesAsync();
            }

            if (MonthlyTrend.Count > 0 && trendChart is not null)
            {
                await trendChart.UpdateOptionsAsync(true, true, true);
                await trendChart.UpdateSeriesAsync();
            }
        }
    }

    private static string GetLicenseBadgeClass(string status) => status switch
    {
        "Valid" => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300",
        "Expiring Soon" => "bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300",
        "Expired" => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300",
        _ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
    };

    private async Task ExportToCsv()
    {
        IsExporting = true;
        try
        {
            var csv = new StringBuilder();
            csv.AppendLine("Driver,License Number,License Status,Current Status,Trips,Avg Rating,Shortage %,Avg Turnaround (d),Needs Attention");

            foreach (var row in DriverPerformance)
            {
                csv.AppendLine(string.Join(",", new[]
                {
                    EscapeCsvValue(row.FullName),
                    EscapeCsvValue(row.LicenseNumber ?? ""),
                    EscapeCsvValue(row.LicenseStatus),
                    EscapeCsvValue(row.CurrentStatus),
                    row.TripCount.ToString(),
                    row.AvgRating.ToString("F1"),
                    row.ShortageRate.ToString("F1"),
                    row.AvgTurnaroundDays.ToString("F1"),
                    row.NeedsAttention ? "Yes" : "No"
                }));
            }

            var fileBytes = Encoding.UTF8.GetBytes(csv.ToString());
            var fileName = $"DriverPerformanceReport_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await ExportService.ExportCsvContent(fileBytes, fileName);
            ToastService.ShowSuccess("Driver report exported successfully");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to export report: {ex.Message}");
        }
        finally
        {
            IsExporting = false;
        }
    }

    private static string EscapeCsvValue(string value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;

        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
        {
            var escaped = value.Replace("\"", "\"\"");
            return "\"" + escaped + "\"";
        }

        return value;
    }

    private void GoToDrilldown(Guid? driverId = null)
    {
        nav.NavigateTo(driverId.HasValue ? $"/drivers/report/drilldown/{driverId}" : "/drivers/report/drilldown");
    }
}

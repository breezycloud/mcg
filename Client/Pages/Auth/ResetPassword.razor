@layout LoginLayout
@page "/reset-password"
@attribute [AllowAnonymous]
@using Shared.Models.Auth
@inject IAuthService AuthService
@inject NavigationManager nav

<section class="bg-gray-50 dark:bg-gray-900 min-h-screen flex items-center justify-center">
    <div class="flex flex-col items-center justify-center px-4 py-8 w-lg">
        <a href="#" class="flex items-center mb-6 text-2xl font-semibold text-gray-900 dark:text-white">
            <img class="w-12 h-12 mr-2" src="favicon.png" alt="logo">
            MCC    
        </a>

        <div class="w-90 bg-white rounded-lg shadow dark:border md:mt-0 xl:p-0 dark:bg-gray-800 dark:border-gray-700">
            <div class="p-6 space-y-4 md:space-y-6 sm:p-8">
                <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl dark:text-white">
                    Reset your password
                </h1>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    Enter a new password for your account.
                </p>

                @if (!string.IsNullOrEmpty(errorMessage) || !hasValidLink)
                {
                    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400" role="alert">
                        @errorMessage
                    </div>
                }

                @if (hasValidLink)
                {
                    <EditForm Model="Model" OnValidSubmit="OnValidSubmit">
                        <DataAnnotationsValidator/>
                        <div class="space-y-4 md:space-y-6">
                            <div>
                                <label for="newPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">New password</label>
                                <InputText @bind-Value="Model.NewPassword" type="password" name="newPassword" id="newPassword" autocomplete="new-password"
                                    class="bg-gray-50 border border-gray-300 text-gray-900 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                                    placeholder="••••••••" />
                                <ValidationMessage For="@(() => Model.NewPassword)" />
                            </div>
                            <div>
                                <label for="confirmPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Confirm password</label>
                                <InputText @bind-Value="Model.ConfirmPassword" type="password" name="confirmPassword" id="confirmPassword" autocomplete="new-password"
                                    class="bg-gray-50 border border-gray-300 text-gray-900 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                                    placeholder="••••••••" />
                                <ValidationMessage For="@(() => Model.ConfirmPassword)" />
                            </div>
                            <button type="submit" disabled="@AppState.IsProcessing" class="w-full flex items-center justify-center text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                                @if (AppState.IsProcessing)
                                {
                                    <svg class="animate-spin h-5 w-5 mr-2 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                                    </svg>
                                    @("Processing...")
                                }
                                else
                                {
                                    @("Reset password")
                                }
                            </button>

                            @if (!string.IsNullOrEmpty(successMessage))
                            {
                                <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400" role="alert">
                                    @successMessage
                                </div>
                            }
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                                Remember your password? <a href="/" class="font-medium text-blue-600 hover:underline dark:text-blue-500">Sign in</a>
                            </p>
                        </div>
                    </EditForm>
                }
            </div>
        </div>  
    </div>
</section>

@code {
    private ResetPasswordModel Model { get; set; } = new();
    private string? errorMessage;
    private string? successMessage;
    private bool hasValidLink;

    [SupplyParameterFromQuery(Name = "userId")]
    public string? UserIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? TokenQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        var userIdStr = UserIdQuery;
        var token = TokenQuery;

        if (string.IsNullOrEmpty(userIdStr) || string.IsNullOrEmpty(token) || !Guid.TryParse(userIdStr, out var parsedUserId))
        {
            errorMessage = "Invalid or expired reset link.";
            hasValidLink = false;
            return;
        }

        Model.UserId = parsedUserId;
        Model.Token = token;
        hasValidLink = true;
    }

    private async Task OnValidSubmit()
    {
        AppState.IsProcessing = true;
        successMessage = null;
        errorMessage = null;
        try
        {
            var result = await AuthService.ResetPassword(Model, AppState.GetCancellationToken());
            if (result)
            {
                successMessage = "Your password has been reset successfully. Redirecting to sign in...";
                await Task.Delay(1500);
                nav.NavigateTo("/", true);
            }
            else
            {
                errorMessage = "Something went wrong. Please try again.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred. Please try again later.";
        }
        finally
        {
            AppState.IsProcessing = false;
        }
    }
}

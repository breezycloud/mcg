    // ─── List helpers ─────────────────────────────────────────────────────────

    /// <summary>
    /// Trims trailing empty tasks and ensures at least 1 row.
    /// Called when loading existing report data into the edit form.
    /// </summary>
    private static void EnsureMinOneTask(List<ReportTask> list)
    {
        while (list.Count > 1 && string.IsNullOrWhiteSpace(list[^1].Text) && string.IsNullOrWhiteSpace(list[^1].ActualNote))
            list.RemoveAt(list.Count - 1);
        if (list.Count == 0)
            list.Add(new ReportTask());
    }

    /// <summary>Remove trailing empty task entries before saving to reduce stored JSONB size.</summary>
    private void TrimTaskLists()
    {
        static void Trim(List<ReportTask> l)
        {
            while (l.Count > 0 && string.IsNullOrWhiteSpace(l[^1].Text) && string.IsNullOrWhiteSpace(l[^1].ActualNote))
                l.RemoveAt(l.Count - 1);
        }
        Trim(_model.WorkTasks);
        Trim(_model.TomorrowTasks);
    }

    private void Cancel() => nav.NavigateTo(_isEdit && Id.HasValue ? $"/view-daily-report/{Id}" : "/daily-reports");
}

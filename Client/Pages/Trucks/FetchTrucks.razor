@page "/trucks"
@using Shared.Dtos
@inject ITruckService TruckService
@inject IDriverService DriverService
@attribute [Authorize(Roles = "Supervisor, Admin, Master, Nrl, DriverSupervisor")]
<PageTitle>Trucks</PageTitle>


<section class="bg-gray-50 dark:bg-gray-900 rounded-lg">
    <div class="px-1 lg:px-12">
        <div class="bg-white dark:bg-gray-800 relative shadow-md sm:rounded-lg overflow-hidden">
            <!-- Header with search and add button -->
            <div class="flex flex-col md:flex-row items-center justify-between gap-4 p-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm">
                <!-- Search Input -->
                <div class="relative w-full md:w-2/3 lg:w-1/2">
                    <label for="truck-search" class="sr-only">Search trucks</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                            <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <input 
                            type="text" 
                            id="truck-search" 
                            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                            placeholder="Search trucks..." 
                            @bind-value="@request.SearchTerm" 
                            @bind-value:event="oninput" 
                            @onkeyup="async () => await HandleSearch(request.SearchTerm!)" />
                    </div>
                </div>

                <button
                    type="button"
                    @onclick="ToggleUnassignedOnly"
                    class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-lg border transition-all duration-200 @(request.UnassignedOnly ? "text-amber-900 bg-amber-100 border-amber-300 dark:text-amber-100 dark:bg-amber-700/50 dark:border-amber-600" : "text-gray-700 bg-white border-gray-200 hover:bg-gray-100 dark:text-gray-200 dark:bg-gray-700 dark:border-gray-600 dark:hover:bg-gray-600")">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-5.414 5.414A1 1 0 0015 13.414V19l-6 3v-8.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                    </svg>
                    @(request.UnassignedOnly ? "Showing Unassigned" : "Without Drivers")
                </button>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                    <a 
                        href="trucks/report" 
                        class="flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-green-600 hover:bg-green-700 dark:bg-green-500 dark:hover:bg-green-600 rounded-lg focus:ring-4 focus:ring-green-200 dark:focus:ring-green-700 transition-all duration-200">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                            <path clip-rule="evenodd" fill-rule="evenodd" d="M5.999 2.5a1.5 1.5 0 011.5 1.5v10.5a1.5 1.5 0 01-3 0V4a1.5 1.5 0 011.5-1.5zM10 2.5a1.5 1.5 0 011.5 1.5v10.5a1.5 1.5 0 01-3 0V4a1.5 1.5 0 011.5-1.5zM14.001 4a1.5 1.5 0 00-1.5 1.5v6.5a1.5 1.5 0 003 0V5.5a1.5 1.5 0 00-1.5-1.5z"></path>
                        </svg>
                        Report
                    </a>
                    <AuthorizeView Roles="Supervisor, Admin, Master" Context="auth">
                        <button 
                            @onclick="AddTruck" 
                            type="button" 
                            class="flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 rounded-lg focus:ring-4 focus:ring-blue-200 dark:focus:ring-blue-700 transition-all duration-200">
                            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path clip-rule="evenodd" fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" />
                            </svg>
                            Add Truck
                        </button>
                    </AuthorizeView>                    
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-100 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th scope="col" class="px-6 py-3">Truck No</th>
                            <th scope="col" class="px-6 py-3">License Plate</th>
                            <th scope="col" class="px-6 py-3">Manufacturer</th>
                            <th scope="col" class="px-6 py-3">Color</th>
                            <th scope="col" class="px-6 py-3">VIN</th>
                            <th scope="col" class="px-6 py-3">Engine No</th>
                            <th scope="col" class="px-6 py-3">Product</th>
                            <th scope="col" class="px-6 py-3">Driver</th>
                            <th scope="col" class="px-6 py-3">Created</th>
                            @* <th scope="col" class="px-6 py-3">Updated</th> *@
                            <th scope="col" class="px-6 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (response != null && response.Data!.Any())
                        {
                            foreach (var truck in response.Data!)
                            {
                                <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                                    <td class="px-6 py-4">@truck.TruckNo</td>
                                    <td class="px-6 py-4">@truck.LicensePlate</td>
                                    <td class="px-6 py-4">@truck.Manufacturer</td>
                                    <td class="px-6 py-4">@truck.Color</td>
                                    <td class="px-6 py-4">@truck.VIN</td>
                                    <td class="px-6 py-4">@truck.EngineNo</td>
                                    <td class="px-6 py-4">@truck.Product</td>
                                    <td class="px-6 py-4">
                                        @if (truck.Driver is not null)
                                        {
                                            <div class="flex flex-col">
                                                <span class="font-medium text-gray-900 dark:text-white">@truck.Driver.FirstName @truck.Driver.LastName</span>
                                                <span class="text-xs text-gray-500 dark:text-gray-400">@truck.Driver.PhoneNo</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-200">
                                                Unassigned
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4">@truck.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    @* <td class="px-6 py-4">@(truck.UpdatedAt?.ToString("MMM dd, yyyy") ?? "Never")</td> *@
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end space-x-3">
                                            <button @onclick="() => ViewTruck(truck.Id)" class="font-medium text-green-600 dark:text-green-500 hover:underline">
                                                View
                                            </button>
                                            <AuthorizeView Roles="Supervisor, Admin, Master, DriverSupervisor" Context="auth">
                                                <button
                                                    @onclick="() => OpenDriverAssignmentModal(truck)"
                                                    class="font-medium text-indigo-600 dark:text-indigo-400 hover:underline">
                                                    @(truck.DriverId is null ? "Add Driver" : "Edit Driver")
                                                </button>
                                                <button 
                                                    @onclick="() => EditTruck(truck.Id)" 
                                                    class="font-medium text-blue-600 dark:text-blue-400 hover:underline">
                                                    Edit
                                                </button>
                                            </AuthorizeView>                                            
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">
                                    @if (AppState.IsBusy)
                                    {
                                        <div class="flex justify-center items-center">
                                            <svg class="animate-spin -ml-1 mr-3 h-4 w-4 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                            </svg>
                                            Loading trucks...
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex flex-col items-center justify-center py-6">
                                            <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                            <span class="text-lg font-medium">No trucks found</span>
                                            <p class="text-sm text-gray-500 mt-1">Try adjusting your search or add a new truck</p>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="p-4 border-t border-gray-200 dark:border-gray-700">
                <Pagination             
                    CurrentPage="request.Page + 1"
                    PageSize="request.PageSize"
                    TotalItems="response?.Total ?? 0"
                    OnPageChanged="async (page) => { 
                        request.Page = page - 1; 
                        await LoadTrucks(); 
                        StateHasChanged(); 
                    }" />
            </div>
        </div>
    </div>
</section>

@if (showDriverAssignmentModal && selectedTruck is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
        <div class="w-full max-w-xl rounded-lg bg-white shadow-lg dark:bg-gray-800">
            <div class="flex items-start justify-between border-b border-gray-200 p-6 dark:border-gray-700">
                <div>
                    <h3 class="text-xl font-semibold text-gray-900 dark:text-white">@(selectedTruck.DriverId is null ? "Assign Driver" : "Edit Driver")</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">@selectedTruck.TruckNo (@selectedTruck.LicensePlate)</p>
                </div>
                <button type="button" @onclick="CloseDriverAssignmentModal" class="flex h-8 w-8 items-center justify-center rounded-lg text-gray-400 hover:bg-gray-200 hover:text-gray-900 dark:text-gray-200 dark:hover:bg-gray-700 dark:hover:text-white">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 14 14">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1l6 6m0 0l6 6M7 7l-6 6m6-6l6-6"></path>
                    </svg>
                </button>
            </div>

            <div class="space-y-5 p-6">
                <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-700/50">
                    <p class="text-sm text-gray-500 dark:text-gray-400">Current driver</p>
                    <p class="mt-1 font-medium text-gray-900 dark:text-white">@(selectedTruck.Driver?.ToString() ?? "Unassigned")</p>
                    <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">Search by driver name or phone. Clear the input and save if you need to remove the current assignment.</p>
                </div>

                <div @key="assignmentAutocompleteKey">
                    <label class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">Driver</label>
                    <Autocomplete TItem="Driver"
                        SearchFunc="SearchDrivers"
                        SelectedChanged="OnDriverSelected"
                        Placeholder="Search driver by name or phone..."
                        InitialText="@selectedDriverName">
                        <OptionTemplate Context="driver">
                            <span>@driver.FirstName @driver.LastName (@driver.PhoneNo)</span>
                        </OptionTemplate>
                    </Autocomplete>
                </div>
            </div>

            <div class="flex justify-end gap-4 border-t border-gray-200 p-6 dark:border-gray-700">
                <button type="button" @onclick="CloseDriverAssignmentModal" class="rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-medium text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-blue-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:hover:border-gray-700 dark:hover:bg-gray-700 dark:focus:ring-gray-700">
                    Cancel
                </button>
                <button type="button"
                        @onclick="SaveDriverAssignmentAsync"
                        disabled="@isSavingDriverAssignment"
                        class="flex min-w-[120px] items-center justify-center rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300 disabled:cursor-not-allowed disabled:opacity-70 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                    @if (isSavingDriverAssignment)
                    {
                        <svg class="mr-2 h-5 w-5 animate-spin text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                        </svg>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Driver</span>
                    }
                </button>
            </div>
        </div>
    </div>
}


@code {
    private GridDataResponse<Truck>? response = null;
    private GridDataRequest request = new();
    private bool showDriverAssignmentModal;
    private bool isSavingDriverAssignment;
    private Truck? selectedTruck;
    private Driver? selectedDriver;
    private string? selectedDriverName;
    private int assignmentAutocompleteKey;

    

    protected override async Task OnInitializedAsync()
    {        
        await LoadTrucks();
    }

    private async Task HandleSearch(string search)
    {
        if (string.IsNullOrWhiteSpace(search))
        {
            request.SearchTerm = string.Empty;
        }
        else
            request.SearchTerm = search;
        request.Page = 0; // Reset to first page when searching
        await LoadTrucks();
    }
    
    private async Task LoadTrucks()
    {
        AppState.IsBusy = true;
        try 
        {            
            response = await TruckService.GetPagedAsync(request, AppState.GetCancellationToken());
        }
        finally
        {
            AppState.IsBusy = false;
        }
        StateHasChanged();
    }

    private async Task ToggleUnassignedOnly()
    {
        request.UnassignedOnly = !request.UnassignedOnly;
        request.Page = 0;
        await LoadTrucks();
    }

    private void AddTruck()
    {
        nav.NavigateTo("/trucks/add");
    }

    private void EditTruck(Guid id)
    {
        nav.NavigateTo($"/trucks/edit/{id}");
    }

    private void ViewTruck(Guid id)
    {
        nav.NavigateTo($"/view-truck/{id}");
    }

    private void OpenDriverAssignmentModal(Truck truck)
    {
        selectedTruck = truck;
        selectedDriver = truck.Driver;
        selectedDriverName = truck.Driver is null ? string.Empty : $"{truck.Driver.FirstName} {truck.Driver.LastName} ({truck.Driver.PhoneNo})";
        assignmentAutocompleteKey++;
        showDriverAssignmentModal = true;
    }

    private void CloseDriverAssignmentModal()
    {
        showDriverAssignmentModal = false;
        selectedTruck = null;
        selectedDriver = null;
        selectedDriverName = null;
    }

    private async Task<List<Driver>> SearchDrivers(string query, int page, CancellationToken ct)
    {
        var driverRequest = new GridDataRequest
        {
            SearchTerm = query,
            Page = page,
            PageSize = 10
        };

        var driverResponse = await DriverService.GetPagedAsync(driverRequest, ct);
        return driverResponse?.Data ?? [];
    }

    private void OnDriverSelected(Driver? driver)
    {
        selectedDriver = driver;
        selectedDriverName = driver is null ? string.Empty : $"{driver.FirstName} {driver.LastName} ({driver.PhoneNo})";
    }

    private async Task SaveDriverAssignmentAsync()
    {
        if (selectedTruck is null)
        {
            return;
        }

        isSavingDriverAssignment = true;
        try
        {
            var model = new TruckDriverAssignmentDto
            {
                TruckId = selectedTruck.Id,
                DriverId = selectedDriver?.Id
            };

            await TruckService.AssignDriverAsync(model, AppState.GetCancellationToken());
            ToastService.ShowSuccess(selectedDriver is null ? "Driver assignment removed successfully" : "Driver assignment updated successfully", 5);
            CloseDriverAssignmentModal();
            await LoadTrucks();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to update driver assignment: {ex.Message}");
        }
        finally
        {
            isSavingDriverAssignment = false;
        }
    }

    private async Task DeleteTruck(Guid id)
    {
        await TruckService.DeleteAsync(id, AppState.GetCancellationToken());
        response = await TruckService.GetPagedAsync(request, AppState.GetCancellationToken());
    }
} 

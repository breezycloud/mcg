@page "/trucks/report/drilldown/{TruckId:guid?}"
@using ApexCharts
@using Shared.Interfaces.Trucks
@inject ITruckService TruckService
@inject ITripService TripService
@attribute [Authorize(Roles = "Admin, Master, Supervisor, Nrl, DriverSupervisor, Manager")]
<PageTitle>Truck Drill-down</PageTitle>

<div class="p-6 space-y-6">
    <div class="flex flex-wrap justify-between items-center gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Truck Drill-down</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Pick a truck to see every trip it made.</p>
        </div>
        <button type="button" @onclick="BackToReport"
            class="px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600">
            Back to Truck Report
        </button>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Truck</label>
                <Autocomplete TItem="Truck"
                    SearchFunc="SearchTrucks"
                    SelectedChanged="OnTruckSelected"
                    Placeholder="Search truck by number or plate..."
                    InitialText="@selectedTruckLabel">
                    <OptionTemplate Context="truck">
                        <span>@truck.TruckNo (@truck.LicensePlate)</span>
                    </OptionTemplate>
                </Autocomplete>
            </div>
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">From (optional)</label>
                <InputDate @bind-Value="drilldownStartDate" @bind-Value:after="LoadDrilldownReport"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"/>
            </div>
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">To (optional)</label>
                <InputDate @bind-Value="drilldownEndDate" @bind-Value:after="LoadDrilldownReport"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"/>
            </div>
        </div>

        @if (selectedTruckId is null)
        {
            <div class="text-center py-10 text-gray-500 dark:text-gray-400">
                Search for and select a truck above to see its trip-level report.
            </div>
        }
        else if (isDrilldownLoading)
        {
            <div class="flex items-center gap-2 text-gray-500 py-10 justify-center">
                <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                </svg>
                Loading report...
            </div>
        }
        else
        {
            <!-- Product breakdown -->
            @if (ProductBreakdown.Count == 0)
            {
                <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">No trips in this period to break down by product.</p>
            }
            else
            {
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 mb-6">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Quantity Dispatched vs. Shortage by Product</h3>
                    <ApexChart @ref="productChart" TItem="ProductSummary" Options="productChartOptions" Height="320">
                        <ApexPointSeries TItem="ProductSummary"
                                         Items="ProductBreakdown"
                                         SeriesType="SeriesType.Bar"
                                         Name="Discharged"
                                         XValue="@(e => e.Product)"
                                         YValue="@(e => e.TotalDelivered)"
                                         ShowDataLabels="true" />
                        <ApexPointSeries TItem="ProductSummary"
                                         Items="ProductBreakdown"
                                         SeriesType="SeriesType.Bar"
                                         Name="Shortage"
                                         XValue="@(e => e.Product)"
                                         YValue="@(e => e.TotalShortage)"
                                         ShowDataLabels="true" />
                    </ApexChart>
                </div>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase border-b border-gray-200 dark:border-gray-700">
                            <tr>
                                <th class="py-2">Product</th>
                                <th class="py-2 text-right">Total Discharged</th>
                                <th class="py-2 text-right">Total Shortage</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in ProductBreakdown)
                            {
                                <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                                    <td class="py-2 font-medium text-gray-900 dark:text-white">@p.Product</td>
                                    <td class="py-2 text-right">@p.TotalDelivered.ToString("N1") @p.Unit</td>
                                    <td class="py-2 text-right @(p.TotalShortage > 0 ? "text-red-600 dark:text-red-400 font-medium" : "")">@p.TotalShortage.ToString("N1") @p.Unit</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Tabs -->
            <div class="border-b border-gray-200 dark:border-gray-700 mb-4">
                <nav class="flex gap-6 -mb-px">
                    <button type="button" @onclick='() => activeTab = "all"'
                        class="py-3 px-1 border-b-2 text-sm font-medium @(activeTab == "all" ? "border-blue-600 text-blue-600 dark:text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")">
                        All Trips (@allRows.Count)
                    </button>
                    <button type="button" @onclick='() => activeTab = "complete"'
                        class="py-3 px-1 border-b-2 text-sm font-medium @(activeTab == "complete" ? "border-blue-600 text-blue-600 dark:text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")">
                        Complete Discharge (@completeRows.Count)
                    </button>
                    <button type="button" @onclick='() => activeTab = "shortage"'
                        class="py-3 px-1 border-b-2 text-sm font-medium @(activeTab == "shortage" ? "border-blue-600 text-blue-600 dark:text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:hover:text-gray-300")">
                        Shortage (@shortageRows.Count)
                    </button>
                </nav>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-100 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th class="px-4 py-2">Date</th>
                            <th class="px-4 py-2">Station(s)</th>
                            <th class="px-4 py-2">Product</th>
                            <th class="px-4 py-2">Driver</th>
                            <th class="px-4 py-2">Loading Depot</th>
                            <th class="px-4 py-2">Loading Date</th>
                            <th class="px-4 py-2 text-right">Dispatch Qty</th>
                            <th class="px-4 py-2 text-right">Discharged Qty</th>
                            <th class="px-4 py-2 text-right cursor-pointer select-none hover:text-gray-900 dark:hover:text-white" @onclick="ToggleShortageSort">
                                <span class="inline-flex items-center gap-1">
                                    Shortage
                                    @if (shortageSort == SortDirection.Ascending)
                                    {
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" clip-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z"/></svg>
                                    }
                                    else if (shortageSort == SortDirection.Descending)
                                    {
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-3 h-3 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20"><path d="M10 3l4 4H6l4-4zm0 14l-4-4h8l-4 4z"/></svg>
                                    }
                                </span>
                            </th>
                            <th class="px-4 py-2">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ActiveRows.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="px-4 py-6 text-center text-gray-500 dark:text-gray-400">No trips found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in ActiveRows)
                            {
                                <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                                    <td class="px-4 py-2">@row.Date.ToString("dd MMM yyyy")</td>
                                    <td class="px-4 py-2">@row.StationNames</td>
                                    <td class="px-4 py-2">@row.Product</td>
                                    <td class="px-4 py-2">@row.DriverName <span class="text-xs text-gray-400">(@row.DriverPhone)</span></td>
                                    <td class="px-4 py-2">@row.LoadingDepot</td>
                                    <td class="px-4 py-2">@row.LoadingDate</td>
                                    <td class="px-4 py-2 text-right">@row.DispatchQuantity.ToString("N1") @row.Unit</td>
                                    <td class="px-4 py-2 text-right">@row.DischargedQuantity.ToString("N1") @row.Unit</td>
                                    <td class="px-4 py-2 text-right @(row.ShortageAmount > 0 ? "text-red-600 dark:text-red-400 font-medium" : row.ShortageAmount < 0 ? "text-amber-600 dark:text-amber-400" : "")">
                                        @row.ShortageAmount.ToString("N1") @row.Unit
                                    </td>
                                    <td class="px-4 py-2">@row.Status</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid? TruckId { get; set; }

    private Guid? selectedTruckId;
    private string? selectedTruckLabel;
    private DateOnly? drilldownStartDate;
    private DateOnly? drilldownEndDate;
    private bool isDrilldownLoading;
    private string activeTab = "all";

    private List<TruckTripReportDto> allRows = [];
    private List<TruckTripReportDto> completeRows = [];
    private List<TruckTripReportDto> shortageRows = [];

    private enum SortDirection { None, Ascending, Descending }
    private SortDirection shortageSort = SortDirection.None;

    private List<TruckTripReportDto> ActiveRows
    {
        get
        {
            var rows = activeTab switch
            {
                "complete" => completeRows,
                "shortage" => shortageRows,
                _ => allRows,
            };

            return shortageSort switch
            {
                SortDirection.Ascending => rows.OrderBy(r => r.ShortageAmount).ToList(),
                SortDirection.Descending => rows.OrderByDescending(r => r.ShortageAmount).ToList(),
                _ => rows,
            };
        }
    }

    // ─── Product breakdown (derived from allRows — every trip in the selected period,
    // regardless of which tab is active) ────────────────────────────────────

    private record ProductSummary(string Product, string Unit, decimal TotalDelivered, decimal TotalShortage, decimal TotalLoaded)
    {
        public decimal ShortageRatePercent => TotalLoaded > 0 ? TotalShortage / TotalLoaded * 100 : 0;
    }

    private List<ProductSummary> ProductBreakdown => allRows
        .GroupBy(r => r.Product ?? "Unknown")
        .Select(g => new ProductSummary(
            g.Key,
            g.FirstOrDefault(r => !string.IsNullOrEmpty(r.Unit))?.Unit ?? "",
            g.Sum(r => r.DischargedQuantity),
            g.Sum(r => Math.Max(0, r.ShortageAmount)),
            g.Sum(r => r.DispatchQuantity)
        ))
        .OrderByDescending(p => p.TotalDelivered)
        .ToList();

    private ApexChart<ProductSummary>? productChart;
    private ApexChartOptions<ProductSummary> productChartOptions = new();

    // Comma-grouped, fixed at 2 decimals — "465,779.84" instead of "465779.8412". Used for
    // both the bar data labels and the Y-axis so the raw jsonb-precision decimals never
    // reach the UI unformatted.
    private const string ReadableNumberFormatter = "function (v) { return v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }";

    protected override async Task OnInitializedAsync()
    {
        productChartOptions = new ApexChartOptions<ProductSummary>
        {
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 4 } },
            Legend = new Legend { Show = true },
            Grid = new Grid { StrokeDashArray = 4 },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Colors = ["#3b82f6", "#ef4444"],
            DataLabels = new DataLabels { Formatter = ReadableNumberFormatter },
            Yaxis = [new YAxis { Labels = new YAxisLabels { Formatter = ReadableNumberFormatter } }]
        };

        if (TruckId.HasValue)
        {
            var truck = await TruckService.GetAsync(TruckId.Value, AppState.GetCancellationToken());
            if (truck != null)
            {
                selectedTruckId = truck.Id;
                selectedTruckLabel = $"{truck.TruckNo} ({truck.LicensePlate})";
                await LoadDrilldownReport();
            }
        }
    }

    private void ToggleShortageSort()
    {
        shortageSort = shortageSort switch
        {
            SortDirection.None => SortDirection.Descending,
            SortDirection.Descending => SortDirection.Ascending,
            _ => SortDirection.None,
        };
    }

    private async Task<List<Truck>> SearchTrucks(string query, int page, CancellationToken ct)
    {
        var request = new GridDataRequest { SearchTerm = query, Page = page, PageSize = 10 };
        var response = await TruckService.GetPagedAsync(request, ct);
        return response?.Data ?? [];
    }

    private async Task OnTruckSelected(Truck? truck)
    {
        selectedTruckId = truck?.Id;
        selectedTruckLabel = truck is null ? null : $"{truck.TruckNo} ({truck.LicensePlate})";
        await LoadDrilldownReport();
    }

    private async Task LoadDrilldownReport()
    {
        if (!selectedTruckId.HasValue)
        {
            return;
        }

        isDrilldownLoading = true;
        StateHasChanged();
        try
        {
            var filter = new TruckTripReportFilter
            {
                TruckId = selectedTruckId.Value,
                StartDate = drilldownStartDate,
                EndDate = drilldownEndDate,
            };
            allRows = await TripService.GetTruckReportAsync(filter, AppState.GetCancellationToken());
            completeRows = allRows.Where(r => r.ShortageAmount == 0).ToList();
            shortageRows = allRows.Where(r => r.ShortageAmount > 50).ToList();
        }
        finally
        {
            isDrilldownLoading = false;
            // Render first so the ApexPointSeries children pick up the new Items via their
            // parameter binding before we ask the chart to re-pull its series — calling
            // UpdateSeriesAsync() before this render would push the chart's *previous* series.
            await InvokeAsync(StateHasChanged);

            if (ProductBreakdown.Count > 0 && productChart is not null)
            {
                // Rebuilt every load — the percentages are only valid for the product order/
                // values of the ProductBreakdown snapshot they were computed from.
                productChartOptions.DataLabels = new DataLabels { Formatter = BuildDataLabelFormatter() };
                await productChart.UpdateOptionsAsync(true, true, true);
                await productChart.UpdateSeriesAsync();
            }
        }
    }

    // One formatter for both series (ApexCharts dataLabels config is chart-wide, not
    // per-series) — branches on opts.seriesIndex so only the Shortage bars (index 1) get the
    // "(x.x%)" suffix, computed as shortage / total quantity loaded for that product. The
    // percentages are baked into the JS as a literal array (indexed by dataPointIndex) rather
    // than looked up from the other series' values, since that's what the formatter actually
    // has reliable access to.
    private string BuildDataLabelFormatter()
    {
        var percents = ProductBreakdown
            .Select(p => p.ShortageRatePercent.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))
            .ToList();
        var percentArrayJs = "[" + string.Join(",", percents) + "]";

        return "function (v, opts) { "
            + "var readable = v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); "
            + "if (opts.seriesIndex === 1) { "
            + "var pct = " + percentArrayJs + "[opts.dataPointIndex]; "
            + "return readable + ' (' + pct + '%)'; "
            + "} "
            + "return readable; "
            + "}";
    }

    private void BackToReport()
    {
        nav.NavigateTo("/trucks/report");
    }
}

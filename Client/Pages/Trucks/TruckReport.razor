@* TruckReport.razor — Fleet Performance Report *@
@page "/trucks/report"
@using System.Text
@using ApexCharts
@using Shared.Enums
@using Shared.Interfaces.Trucks
@using Shared.Models.Trucks
@inject ITruckReportService TruckReportService
@inject IExportService ExportService
@attribute [Authorize(Roles = "Supervisor, Admin, Master, Nrl, DriverSupervisor, Manager")]

<div class="p-6 space-y-6">
    <!-- Header -->
    <div class="flex flex-wrap justify-between items-center gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Fleet Performance Report</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Utilization, turnaround, maintenance and compliance across the fleet</p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <select @bind="SelectedProduct" @bind:after="LoadDataAsync"
                    class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                <option value="All">All Products</option>
                @foreach (var p in Enum.GetValues<Product>())
                {
                    <option value="@p">@FormatProduct(p.ToString())</option>
                }
            </select>

            <div class="flex rounded-lg overflow-hidden border border-gray-300 dark:border-gray-600 text-sm">
                <button @onclick="@(() => SetPeriod(PeriodFilter.ThisMonth))"
                        class="px-3 py-2 font-medium @(Period == PeriodFilter.ThisMonth ? "bg-blue-600 text-white" : "bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600")">
                    This Month
                </button>
                <button @onclick="@(() => SetPeriod(PeriodFilter.AllTime))"
                        class="px-3 py-2 font-medium @(Period == PeriodFilter.AllTime ? "bg-blue-600 text-white" : "bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600")">
                    All Time
                </button>
            </div>

            <button @onclick="ExportToCsv" disabled="@IsExporting"
                    class="px-4 py-2.5 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 disabled:opacity-50 flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                @(IsExporting ? "Exporting..." : "Export CSV")
            </button>

            <button type="button" @onclick="() => GoToDrilldown()"
                class="px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600">
                Truck Drill-down
            </button>
        </div>
    </div>

    @if (IsLoading && Metrics is null)
    {
        <Loader />
    }
    else
    {
        <!-- North-star KPIs -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <MetricCard Label="Fleet Utilization" Large="true" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.FleetUtilizationRate ?? 0)" Decimals="0" Suffix="%" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Fleet Availability" Large="true" SubValue="Deployed trucks not under repair"
                        Accent="@((Metrics?.FleetAvailabilityRate ?? 100) < 90 ? "text-red-500" : "text-gray-900 dark:text-white")">
                <ValueContent>
                    <span class="inline-flex items-center gap-1">
                        <AnimatedNumber Value="@(Metrics?.FleetAvailabilityRate ?? 0)" Decimals="0" Suffix="%" />
                        @if ((Metrics?.FleetAvailabilityRate ?? 100) < 90)
                        {
                            <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <span class="sr-only">— below the 90% threshold</span>
                        }
                    </span>
                </ValueContent>
            </MetricCard>
            <MetricCard Label="Avg Turnaround" Large="true" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.AvgTurnaroundDays ?? 0)" Decimals="1" Suffix="d" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Shortage Rate" Large="true" SubValue="@PeriodLabel"
                        Accent="@((Metrics?.ShortageRate ?? 0) > 20 ? "text-red-500" : "text-gray-900 dark:text-white")">
                <ValueContent>
                    <span class="inline-flex items-center gap-1">
                        <AnimatedNumber Value="@(Metrics?.ShortageRate ?? 0)" Decimals="1" Suffix="%" />
                        @if ((Metrics?.ShortageRate ?? 0) > 20)
                        {
                            <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <span class="sr-only">— above the 20% threshold</span>
                        }
                    </span>
                </ValueContent>
            </MetricCard>
        </div>

        <!-- Supporting KPIs -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
            <MetricCard Label="Deployed Trucks" Value="@($"{Metrics?.TotalDeployedTrucks}/{Metrics?.TotalTrucksInFleet}")" />
            <MetricCard Label="Loaded" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.TrucksLoadedInPeriod ?? 0)" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Trips" SubValue="@PeriodLabel">
                <ValueContent><AnimatedNumber Value="@(Metrics?.TripsInPeriod ?? 0)" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Quantity Loaded" Value="@((Metrics?.TotalQuantityLoaded ?? 0).ToString("N0"))" SubValue="@PeriodLabel" />
            <MetricCard Label="Open Service Req." SubValue="@($"{Metrics?.AvgMaintenanceTatDays:F1}d avg TAT")">
                <ValueContent><AnimatedNumber Value="@(Metrics?.OpenServiceRequests ?? 0)" /></ValueContent>
            </MetricCard>
            <MetricCard Label="Open Incidents" Accent="@((Metrics?.OpenIncidents ?? 0) > 0 ? "text-orange-500" : "text-gray-900 dark:text-white")">
                <ValueContent>
                    <span class="inline-flex items-center gap-1">
                        <AnimatedNumber Value="@(Metrics?.OpenIncidents ?? 0)" />
                        @if ((Metrics?.OpenIncidents ?? 0) > 0)
                        {
                            <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <span class="sr-only">— incidents require attention</span>
                        }
                    </span>
                </ValueContent>
            </MetricCard>
        </div>

        <!-- Status breakdown + monthly trend -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Fleet Status Breakdown</h3>
                @if (StatusBreakdown.Count == 0)
                {
                    <p class="text-gray-500 dark:text-gray-400 text-sm">No trucks match this filter.</p>
                }
                <div class="@(StatusBreakdown.Count == 0 ? "hidden" : "")">
                    <ApexChart @ref="statusChart" TItem="TruckStatusBreakdownDto" Options="statusChartOptions" Height="300">
                        <ApexPointSeries TItem="TruckStatusBreakdownDto"
                                         Items="StatusBreakdown"
                                         SeriesType="SeriesType.Bar"
                                         Name="Trucks"
                                         XValue="@(e => e.Status)"
                                         YValue="@(e => (decimal)e.Count)"
                                         ShowDataLabels="true" />
                    </ApexChart>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">6-Month Trend</h3>
                @if (MonthlyTrend.Count == 0)
                {
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Not enough data yet.</p>
                }
                <div class="@(MonthlyTrend.Count == 0 ? "hidden" : "")">
                    <ApexChart @ref="trendChart" TItem="FleetMonthlyTrendDto" Options="trendChartOptions" Height="300">
                        <ApexPointSeries TItem="FleetMonthlyTrendDto"
                                         Items="MonthlyTrend"
                                         SeriesType="SeriesType.Line"
                                         Name="Utilization %"
                                         XValue="@(e => e.Format)"
                                         YValue="@(e => e.UtilizationRate)" />
                        <ApexPointSeries TItem="FleetMonthlyTrendDto"
                                         Items="MonthlyTrend"
                                         SeriesType="SeriesType.Line"
                                         Name="Shortage %"
                                         XValue="@(e => e.Format)"
                                         YValue="@(e => e.ShortageRate)" />
                    </ApexChart>
                </div>
            </div>
        </div>

        <!-- Per-truck performance -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Truck Performance &middot; @PeriodLabel</h3>
                <span class="text-sm text-gray-500 dark:text-gray-400">@TruckPerformance.Count trucks &middot; click a row to drill in</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                        <tr>
                            <th class="px-4 py-3"></th>
                            <th class="px-4 py-3">Truck</th>
                            <th class="px-4 py-3">Product</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Driver</th>
                            <th class="px-4 py-3 text-center">Trips</th>
                            <th class="px-4 py-3 text-right">Quantity</th>
                            <th class="px-4 py-3 text-center">Shortage</th>
                            <th class="px-4 py-3 text-center">Avg Turnaround</th>
                            <th class="px-4 py-3 text-center">Open SR</th>
                            <th class="px-4 py-3 text-center">Open Inc.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in TruckPerformance)
                        {
                            <tr @key="row.TruckId" @onclick="() => GoToDrilldown(row.TruckId)"
                                class="bg-white dark:bg-gray-800 border-b dark:border-gray-700 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 @(row.NeedsAttention ? "border-l-4 border-l-red-500" : "")">
                                <td class="px-2 text-center">
                                    @if (row.NeedsAttention)
                                    {
                                        <span title="Needs attention" class="text-red-500">&#9888;</span>
                                    }
                                </td>
                                <td class="px-4 py-3 font-medium text-gray-900 dark:text-white whitespace-nowrap">@row.TruckNo</td>
                                <td class="px-4 py-3">@FormatProduct(row.Product)</td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 text-xs font-medium rounded-full @GetStatusBadgeClass(row.Status)">@row.Status</span>
                                </td>
                                <td class="px-4 py-3">@(row.DriverName ?? "Unassigned")</td>
                                <td class="px-4 py-3 text-center">@row.TripCount</td>
                                <td class="px-4 py-3 text-right">@row.TotalQuantity.ToString("N0")</td>
                                <td class="px-4 py-3 text-center @(row.ShortageRate > 20 ? "text-red-500 font-medium" : "")">@row.ShortageRate.ToString("F1")%</td>
                                <td class="px-4 py-3 text-center">@row.AvgTurnaroundDays.ToString("F1")d</td>
                                <td class="px-4 py-3 text-center @(row.OpenServiceRequests > 0 ? "text-orange-500 font-medium" : "")">@row.OpenServiceRequests</td>
                                <td class="px-4 py-3 text-center @(row.OpenIncidents > 0 ? "text-orange-500 font-medium" : "")">@row.OpenIncidents</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Maintenance spend -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Top Maintenance Spend by Truck &middot; @PeriodLabel</h3>
                @if (MaintenanceByTruck.Count == 0)
                {
                    <p class="text-gray-500 dark:text-gray-400 text-sm">No costed service requests in this period.</p>
                }
                else
                {
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase border-b border-gray-200 dark:border-gray-700">
                            <tr>
                                <th class="py-2">Truck</th>
                                <th class="py-2 text-center">Requests</th>
                                <th class="py-2 text-center">Avg TAT</th>
                                <th class="py-2 text-right">Total Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in MaintenanceByTruck)
                            {
                                <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                                    <td class="py-2 font-medium text-gray-900 dark:text-white">@entry.TruckNo</td>
                                    <td class="py-2 text-center">@entry.RequestCount</td>
                                    <td class="py-2 text-center">@entry.AvgTatDays.ToString("F1")d</td>
                                    <td class="py-2 text-right">@entry.TotalCost.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Maintenance Spend by Category &middot; @PeriodLabel</h3>
                @if (MaintenanceByCategory.Count == 0)
                {
                    <p class="text-gray-500 dark:text-gray-400 text-sm">No costed service requests in this period.</p>
                }
                else
                {
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase border-b border-gray-200 dark:border-gray-700">
                            <tr>
                                <th class="py-2">Category</th>
                                <th class="py-2 text-center">Requests</th>
                                <th class="py-2 text-right">Total Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in MaintenanceByCategory)
                            {
                                <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                                    <td class="py-2 font-medium text-gray-900 dark:text-white">@entry.Category</td>
                                    <td class="py-2 text-center">@entry.RequestCount</td>
                                    <td class="py-2 text-right">@entry.TotalCost.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Calibration compliance -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Calibration Compliance &middot; expiring within 30 days</h3>
            @if (CalibrationExpiry.Count == 0)
            {
                <p class="text-gray-500 dark:text-gray-400 text-sm">No calibration certificates expiring or overdue.</p>
            }
            else
            {
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase border-b border-gray-200 dark:border-gray-700">
                        <tr>
                            <th class="py-2">Truck</th>
                            <th class="py-2">Expiry Date</th>
                            <th class="py-2 text-center">Days</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in CalibrationExpiry)
                        {
                            <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                                <td class="py-2 font-medium text-gray-900 dark:text-white">@entry.TruckNo</td>
                                <td class="py-2">@entry.ExpiryDate.ToString("dd MMM yyyy")</td>
                                <td class="py-2 text-center @(entry.DaysUntilExpiry < 0 ? "text-red-500 font-medium" : "text-orange-500")">
                                    @(entry.DaysUntilExpiry < 0 ? $"Overdue {-entry.DaysUntilExpiry}d" : $"{entry.DaysUntilExpiry}d")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@code {
    private enum PeriodFilter { ThisMonth, AllTime }

    private PeriodFilter Period = PeriodFilter.ThisMonth;
    private string SelectedProduct = "All";

    private TruckFleetReportMetricsDto? Metrics;
    private List<TruckStatusBreakdownDto> StatusBreakdown = [];
    private List<TruckPerformanceRowDto> TruckPerformance = [];
    private List<MaintenanceSpendByTruckDto> MaintenanceByTruck = [];
    private List<MaintenanceSpendByCategoryDto> MaintenanceByCategory = [];
    private List<CalibrationExpiryDto> CalibrationExpiry = [];
    private List<FleetMonthlyTrendDto> MonthlyTrend = [];

    private bool IsLoading;
    private bool IsExporting;

    private ApexChart<TruckStatusBreakdownDto>? statusChart;
    private ApexChartOptions<TruckStatusBreakdownDto> statusChartOptions = new();

    private ApexChart<FleetMonthlyTrendDto>? trendChart;
    private ApexChartOptions<FleetMonthlyTrendDto> trendChartOptions = new();

    private string PeriodLabel => Period == PeriodFilter.ThisMonth ? "This Month" : "All Time";

    private DateOnly? StartDateParam => Period == PeriodFilter.ThisMonth
        ? new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1)
        : null;

    protected override async Task OnInitializedAsync()
    {
        statusChartOptions = new ApexChartOptions<TruckStatusBreakdownDto>
        {
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, Distributed = true, BorderRadius = 4 } },
            Legend = new Legend { Show = false },
            Grid = new Grid { StrokeDashArray = 4 },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } }
        };

        trendChartOptions = new ApexChartOptions<FleetMonthlyTrendDto>
        {
            Colors = ["#3b82f6", "#ef4444"],
            Grid = new Grid { StrokeDashArray = 4 },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Yaxis = [new YAxis { Labels = new YAxisLabels { Formatter = "function (v) { return v.toFixed(2) + '%'; }" } }]
        };

        await LoadDataAsync();
    }

    private async Task SetPeriod(PeriodFilter period)
    {
        if (Period == period)
            return;

        Period = period;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var startDate = StartDateParam;
            var product = SelectedProduct;

            var metricsTask = TruckReportService.GetMetricsAsync(startDate, product);
            var statusTask = TruckReportService.GetStatusBreakdownAsync(product);
            var performanceTask = TruckReportService.GetTruckPerformanceAsync(startDate, product);
            var maintByTruckTask = TruckReportService.GetMaintenanceSpendByTruckAsync(startDate);
            var maintByCategoryTask = TruckReportService.GetMaintenanceSpendByCategoryAsync(startDate);
            var calibrationTask = TruckReportService.GetCalibrationExpiryAsync();
            var trendTask = TruckReportService.GetMonthlyTrendAsync(6, product);

            await Task.WhenAll(metricsTask, statusTask, performanceTask, maintByTruckTask, maintByCategoryTask, calibrationTask, trendTask);

            Metrics = await metricsTask;
            StatusBreakdown = await statusTask;
            TruckPerformance = await performanceTask;
            MaintenanceByTruck = await maintByTruckTask;
            MaintenanceByCategory = await maintByCategoryTask;
            CalibrationExpiry = await calibrationTask;
            MonthlyTrend = await trendTask;
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to load fleet report: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            // Render first so the ApexPointSeries children pick up the new Items via their
            // parameter binding before we ask the charts to re-pull their series — calling
            // UpdateSeriesAsync() before this render would push each chart's *previous* series.
            await InvokeAsync(StateHasChanged);

            if (StatusBreakdown.Count > 0 && statusChart is not null)
            {
                // Distributed bar coloring needs Colors to match StatusBreakdown's current order —
                // recomputed every load since which statuses are present (and their order) varies.
                statusChartOptions.Colors = StatusBreakdown.Select(s => GetStatusColor(s.Status)).ToList();
                await statusChart.UpdateOptionsAsync(true, true, true);
                await statusChart.UpdateSeriesAsync();
            }

            if (MonthlyTrend.Count > 0 && trendChart is not null)
            {
                await trendChart.UpdateOptionsAsync(true, true, true);
                await trendChart.UpdateSeriesAsync();
            }
        }
    }

    // Status colors are reserved by severity, not by category identity — every truck-status label
    // is also shown as visible text (bar category / table badge), so the palette only needs to be
    // discriminable at a glance, not individually distinguishable per one of the ~9 status labels.
    private static string GetStatusColor(string status) => status switch
    {
        "Out of Service" => "#ef4444",
        "Under Repair" => "#d97706",
        "Awaiting Loading" => "#64748b",
        _ => "#3b82f6"
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Out of Service" => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300",
        "Under Repair" => "bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300",
        "Awaiting Loading" => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300",
        _ => "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300"
    };

    private static string FormatProduct(string? product)
    {
        if (string.IsNullOrWhiteSpace(product)) return "N/A";
        return product switch
        {
            "CngAbuja" => "CNG-Abuja",
            "CngLagos" => "CNG-Lagos",
            _ => product
        };
    }

    private async Task ExportToCsv()
    {
        IsExporting = true;
        try
        {
            var csv = new StringBuilder();
            csv.AppendLine("Truck,Product,Status,Driver,Trips,Quantity,Shortage %,Avg Turnaround (d),Open Service Requests,Open Incidents,Needs Attention");

            foreach (var row in TruckPerformance)
            {
                csv.AppendLine(string.Join(",", new[]
                {
                    EscapeCsvValue(row.TruckNo),
                    EscapeCsvValue(FormatProduct(row.Product)),
                    EscapeCsvValue(row.Status),
                    EscapeCsvValue(row.DriverName ?? "Unassigned"),
                    row.TripCount.ToString(),
                    row.TotalQuantity.ToString("N0"),
                    row.ShortageRate.ToString("F1"),
                    row.AvgTurnaroundDays.ToString("F1"),
                    row.OpenServiceRequests.ToString(),
                    row.OpenIncidents.ToString(),
                    row.NeedsAttention ? "Yes" : "No"
                }));
            }

            var fileBytes = Encoding.UTF8.GetBytes(csv.ToString());
            var fileName = $"FleetPerformanceReport_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await ExportService.ExportCsvContent(fileBytes, fileName);
            ToastService.ShowSuccess("Fleet report exported successfully");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to export report: {ex.Message}");
        }
        finally
        {
            IsExporting = false;
        }
    }

    private static string EscapeCsvValue(string value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;

        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
        {
            var escaped = value.Replace("\"", "\"\"");
            return "\"" + escaped + "\"";
        }

        return value;
    }

    private void GoToDrilldown(Guid? truckId = null)
    {
        nav.NavigateTo(truckId.HasValue ? $"/trucks/report/drilldown/{truckId}" : "/trucks/report/drilldown");
    }
}

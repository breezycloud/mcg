<div class="overflow-x-auto rounded-lg border border-gray-100 dark:border-gray-700">
    <table class="w-full text-sm text-left">
        <thead class="text-[11px] text-gray-500 dark:text-gray-400 uppercase tracking-wide bg-gray-50 dark:bg-gray-900/40">
            <tr>
                @if (Product == Product.LPG)
                {
                    <th scope="col" class="px-3 py-2">Tare</th>
                    <th scope="col" class="px-3 py-2">Gross</th>
                    <th scope="col" class="px-3 py-2">Net</th>
                }
                else
                {
                    <th scope="col" class="px-3 py-2">Item</th>
                    <th scope="col" class="px-3 py-2">Ullage</th>
                    <th scope="col" class="px-3 py-2">Liquid Height</th>
                    <th scope="col" class="px-3 py-2">Overall</th>
                }
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            @foreach (var metric in MetricsList)
            {
                <tr class="text-gray-700 dark:text-gray-200">
                    @if (Product == Product.LPG)
                    {
                        <td class="px-3 py-1.5">@metric.TareWeight?.ToString("N1") kg</td>
                        <td class="px-3 py-1.5">@metric.GrossWeight?.ToString("N1") kg</td>
                        <td class="px-3 py-1.5">@metric.NetWeight.ToString("N1") kg</td>
                    }
                    else
                    {
                        <td class="px-3 py-1.5 font-medium text-gray-900 dark:text-white whitespace-nowrap">@metric.Compartment</td>
                        <td class="px-3 py-1.5">@metric.Ullage?.Quantity?.ToString("N1")</td>
                        <td class="px-3 py-1.5">@metric.LiquidHeight?.Quantity?.ToString("N1")</td>
                        <td class="px-3 py-1.5 font-medium">@metric.Overall?.ToString("N1")</td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public Product Product { get; set; }

    [Parameter]
    public List<Metrics> MetricsList { get; set; } = new();
}

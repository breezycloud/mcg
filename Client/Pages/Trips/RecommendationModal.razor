@inject IJSRuntime JSRuntime
@implements IDisposable

@if (IsVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-gray bg-opacity-50 p-4">
        <div id="@_dialogId" class="relative w-full max-w-lg bg-white rounded-lg shadow dark:bg-gray-700"
             role="dialog" aria-modal="true" aria-label="Record CCU Recommendation" tabindex="-1">
            <div class="flex items-start justify-between p-4 border-b rounded-t dark:border-gray-600">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Record CCU Recommendation</h3>
                <button type="button" @onclick="Close" aria-label="Close"
                        class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white">
                    <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                    </svg>
                </button>
            </div>

            <div class="p-4 md:p-5 space-y-4">
                <div>
                    <label for="rec-amount" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                        Recommended Shortage Amount <span class="text-red-500">*</span>
                    </label>
                    <input type="number" step="any" id="rec-amount" @bind="Data.RecommendedShortageAmount"
                           class="@GetInputClass("RecommendedShortageAmount")" aria-invalid="@errors.ContainsKey("RecommendedShortageAmount")" />
                    @if (errors.ContainsKey("RecommendedShortageAmount"))
                    {
                        <p class="mt-1 text-sm text-red-600 dark:text-red-500">@errors["RecommendedShortageAmount"]</p>
                    }
                </div>

                <div>
                    <label for="rec-ref" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                        CCU Reference Number
                    </label>
                    <input type="text" id="rec-ref" @bind="Data.CcuReferenceNumber" class="@GetInputClass("CcuReferenceNumber")" />
                </div>

                <div>
                    <label for="rec-date" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                        Date Received <span class="text-red-500">*</span>
                    </label>
                    <input type="date" id="rec-date" @bind="receivedDate"
                           class="@GetInputClass("ReceivedDate")" aria-invalid="@errors.ContainsKey("ReceivedDate")" />
                    @if (errors.ContainsKey("ReceivedDate"))
                    {
                        <p class="mt-1 text-sm text-red-600 dark:text-red-500">@errors["ReceivedDate"]</p>
                    }
                </div>

                <div>
                    <label for="rec-remarks" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                        Remarks
                    </label>
                    <textarea id="rec-remarks" rows="3" maxlength="500" @bind="Data.Remarks" class="@GetInputClass("Remarks")"></textarea>
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 p-4 border-t dark:border-gray-600">
                <button type="button" @onclick="Close"
                        class="py-2.5 px-5 text-sm font-medium text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600">
                    Cancel
                </button>
                <button type="button" @onclick="Save" disabled="@IsSubmitting"
                        class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 disabled:opacity-50">
                    @(IsSubmitting ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid TripId { get; set; }
    [Parameter] public EventCallback<ShortageRecommendation> OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool IsVisible { get; set; }
    private bool IsSubmitting { get; set; }
    private bool _pendingActivate;
    private readonly string _dialogId = $"recommendation-modal-{Guid.NewGuid():N}";
    private DotNetObjectReference<RecommendationModal>? _dotNetRef;

    private ShortageRecommendation Data { get; set; } = new();
    private DateTime receivedDate = DateTime.Today;
    private Dictionary<string, string> errors = new();

    public void Show()
    {
        Data = new ShortageRecommendation { TripId = TripId };
        receivedDate = DateTime.Today;
        errors.Clear();
        IsVisible = true;
        _pendingActivate = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingActivate)
        {
            _pendingActivate = false;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("focusTrap.activate", _dialogId, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnEscapePressed() => await Close();

    private string GetInputClass(string fieldName)
    {
        var baseClass = "bg-gray-50 border text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500";
        return errors.ContainsKey(fieldName)
            ? $"{baseClass} border-red-500 bg-red-50 dark:bg-red-900 dark:border-red-700"
            : $"{baseClass} border-gray-300";
    }

    private bool Validate()
    {
        errors.Clear();
        if (Data.RecommendedShortageAmount <= 0)
        {
            errors["RecommendedShortageAmount"] = "Enter the recommended shortage amount";
        }
        if (receivedDate == default)
        {
            errors["ReceivedDate"] = "Date is required";
        }
        return errors.Count == 0;
    }

    private async Task Save()
    {
        if (!Validate())
        {
            StateHasChanged();
            return;
        }

        Data.ReceivedDate = receivedDate;
        IsSubmitting = true;
        try
        {
            await OnSave.InvokeAsync(Data);
            await Close();
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task Close()
    {
        await JSRuntime.InvokeVoidAsync("focusTrap.deactivate", _dialogId);
        IsVisible = false;
        await OnClose.InvokeAsync();
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}

@page "/view-trip/{id:guid}"
@using Client.Pages.Modals
@inject ITripService TripService
@inject IShortageRecommendationService ShortageRecommendationService
@inject IJSRuntime JSRuntime
@attribute [Authorize (Roles = "Admin, Master, Monitoring, Supervisor, Nrl, DriverSupervisor, Manager")]

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 bg-gray-100 dark:bg-gray-900 min-h-screen">
    @if (AppState.IsBusy)
    {
        <Loader />
    }
    else
    {
        <ConfirmationModal @ref="deleteModal" Title="Delete Trip"
                            Message="Are you sure you want to delete this trip? This action cannot be undone."
                            OnClose="HandleDeleteModalClose" />

        <!-- Hero -->
        <div class="bg-slate-900 dark:bg-slate-950 rounded-3xl shadow-lg p-5 sm:p-6 mb-4">
            <div class="flex items-start justify-between gap-3">
                <div>
                    <div class="text-slate-400 text-xs font-medium uppercase tracking-wide">Trip</div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-white leading-tight">@Trip?.DispatchId</h1>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <span class="@GetStatusBadgeClass(Trip?.Status ?? TripStatus.Active) inline-flex items-center gap-1 text-xs font-semibold px-3 py-1 rounded-full">
                        @Trip?.Status
                    </span>
                    <div class="flex gap-1.5">
                        <AuthorizeView Roles="Admin, Master, Monitoring, Supervisor, DriverSupervisor, Manager" Context="auth">
                            <Authorized>
                                @if (Trip.Status != TripStatus.Completed)
                                {
                                    <button class="px-2.5 py-1 bg-white/10 hover:bg-white/20 text-white rounded-lg text-xs font-medium border border-white/10"
                                            @onclick="() => OnEditTrip()" aria-label="Edit trip details">
                                        Edit
                                    </button>
                                }
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Roles="Admin, Master, Manager" Context="auth">
                            <Authorized>
                                <button class="px-2.5 py-1 bg-white/10 hover:bg-red-500/80 text-white rounded-lg text-xs font-medium border border-white/10"
                                        @onclick="() => deleteModal.Show()" aria-label="Delete trip">
                                    Delete
                                </button>
                            </Authorized>
                        </AuthorizeView>
                        <button class="px-2.5 py-1 bg-white/10 hover:bg-white/20 text-white rounded-lg text-xs font-medium border border-white/10"
                                @onclick="() => OnBackToTrips()" aria-label="Return to trips list">
                            Back
                        </button>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5 mt-5">
                <StatChip Label="Loaded" Value="@(Trip?.LoadingInfo?.Quantity?.ToString("N0") ?? "0")" Unit="@Trip?.GetUnit()" ColorClass="bg-blue-600" />
                <StatChip Label="Discharged" Value="@TotalDischarged.ToString("N0")" Unit="@Trip?.GetUnit()" ColorClass="bg-emerald-600" />
                <StatChip Label="Remaining" Value="@Remaining.ToString("N0")" Unit="@Trip?.GetUnit()" ColorClass="bg-amber-600" />
                @if (HasFinalDischarge)
                {
                    <StatChip Label="Shortage" Value="@ShortageAmount.ToString("N0")" Unit="@Trip?.GetUnit()"
                              ColorClass="@(ShortageAmount > 0 ? "bg-red-600" : "bg-slate-700")"
                              BadgeText="@(ShortageAmount > 0 ? (Recommendations.Any() ? "✓ CCU Logged" : "CCU Pending") : null)"
                              BadgeColorClass="@(Recommendations.Any() ? "bg-emerald-500 text-white" : "bg-amber-400 text-slate-900")" />
                }
            </div>
        </div>

        <!-- Journey -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5 mb-4">
            <h3 class="text-sm font-bold text-gray-800 dark:text-white mb-4">Trip Progress</h3>
            <div class="flex items-start">
                @{
                    var steps = JourneySteps;
                    var currentIndex = steps.FindIndex(s => !s.Done);
                    if (currentIndex == -1) currentIndex = steps.Count;
                }
                @for (var i = 0; i < steps.Count; i++)
                {
                    var step = steps[i];
                    var isCurrent = i == currentIndex;
                    var isLast = i == steps.Count - 1;
                    <div class="flex items-center @(isLast ? "" : "flex-1")">
                        <div class="flex flex-col items-center w-16 flex-shrink-0">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 @(step.Done ? "bg-emerald-500" : isCurrent ? "bg-blue-600 ring-4 ring-blue-100 dark:ring-blue-950" : "bg-gray-200 dark:bg-gray-700")">
                                @if (step.Done)
                                {
                                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                    </svg>
                                }
                                else
                                {
                                    <span class="w-2 h-2 rounded-full @(isCurrent ? "bg-white" : "bg-gray-400 dark:bg-gray-500")"></span>
                                }
                            </div>
                            <div class="mt-2 text-xs font-semibold text-center @(step.Done || isCurrent ? "text-gray-800 dark:text-gray-100" : "text-gray-400 dark:text-gray-500")">@step.Label</div>
                            <div class="text-[11px] text-gray-400 dark:text-gray-500 text-center">@(step.Date ?? " ")</div>
                        </div>
                        @if (!isLast)
                        {
                            <div class="flex-1 h-0.5 mt-4 @(step.Done ? "bg-emerald-500" : "bg-gray-200 dark:bg-gray-700")"></div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Main grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-2 space-y-4">
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5">
                    <h3 class="text-sm font-bold text-gray-800 dark:text-white mb-3">Trip Details</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-x-4 gap-y-3">
                        <DetailBlock Label="Waybill" Value="@Trip?.LoadingInfo?.WaybillNo" />
                        <DetailBlock Label="Date" Value="@Trip?.Date.ToString("dd MMM yyyy")" />
                        <DetailBlock Label="Driver" Value="@Trip?.Driver?.ToString()" />
                        <DetailBlock Label="Truck" Value="@Trip?.Truck?.LicensePlate" />
                        <DetailBlock Label="Product" Value="@Trip?.Truck?.Product.Value.ToDisplay()" />
                        <DetailBlock Label="Loading Depot" Value="@Trip?.LoadingDepot?.Name" />
                        <DetailBlock Label="Receiving Depot" Value="@Trip?.ReceivingDepot?.Name" />
                        <DetailBlock Label="Destination" Value="@(Trip?.ArrivalInfo?.ArrivedAtStation == true ? Trip?.LoadingInfo?.Destination : Trip?.ArrivalInfo?.ArrivedDepot == true ? Trip?.ReceivingDepot?.Name : null)" />
                        <DetailBlock Label="Created By" Value="@Trip?.CreatedBy?.ToString()" />
                    </div>
                    @if (Trip?.LoadingInfo?.Files != null && Trip.LoadingInfo.Files.Any())
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700 flex flex-wrap gap-1.5">
                            @foreach (var file in Trip.LoadingInfo.Files)
                            {
                                <FileChip File="file" OnPreview="(f) => loadingFilePreview.Show(f)" />
                            }
                        </div>
                    }
                </div>
                <FilePreviewModal @ref="loadingFilePreview" />

                @if (!Product.IsCng())
                {
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5">
                        <h3 class="text-sm font-bold text-gray-800 dark:text-white mb-3">Compartment Readings</h3>
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                            <div>
                                <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Loading</div>
                                <TripParams Product="@Product" MetricsList="Trip?.LoadingInfo.Metrics"/>
                            </div>
                            <div>
                                <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Arrival</div>
                                <TripParams Product="@Product" MetricsList="Trip?.Metrics"/>
                            </div>
                        </div>
                    </div>
                }

                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-sm font-bold text-gray-800 dark:text-white">Discharges</h3>
                        @{
                            var sidingCount = Trip?.Discharges?.Count(d => d.IsSiding) ?? 0;
                            var totalDischarges = Trip?.Discharges?.Count ?? 0;
                        }
                        @if (sidingCount > 0)
                        {
                            <div class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200">
                                @sidingCount/@totalDischarges SIDING
                            </div>
                        }
                    </div>

                    @if (Trip?.Discharges != null && Trip.Discharges.Any())
                    {
                        <div class="divide-y divide-gray-100 dark:divide-gray-700 max-h-96 overflow-y-auto pr-1">
                            @foreach (var discharge in Trip.Discharges.OrderBy(d => d.DischargeStartTime))
                            {
                                <DischargeCard Data="discharge"
                                               OnDelete="DeleteDischarge"
                                               OnEdit="EditDischarge"
                                               Compact="true" />
                            }
                        </div>

                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700 flex flex-wrap items-center justify-between gap-2">
                            <div class="text-sm">
                                <span class="text-gray-500 dark:text-gray-400">Total Discharged:</span>
                                <span class="ml-1.5 text-base font-bold text-emerald-600 dark:text-emerald-400">
                                    @TotalDischarged.ToString("N0") @Trip.GetUnit()
                                </span>
                            </div>
                            @if (Remaining > 0)
                            {
                                <div class="text-sm">
                                    <span class="text-gray-500 dark:text-gray-400">Remaining:</span>
                                    <span class="ml-1.5 font-semibold text-amber-600 dark:text-amber-400">@Remaining.ToString("N0") @Trip.GetUnit()</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8 text-gray-500 dark:text-gray-400 text-sm">No discharge records yet</div>
                    }
                </div>
            </div>

            <div class="space-y-4">
                @if (ShortageAmount > 0)
                {
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5">
                        <div class="flex justify-between items-start gap-2 mb-2">
                            <h3 class="text-sm font-bold text-gray-800 dark:text-white">Shortage &amp; CCU</h3>
                            <span class="text-sm font-bold text-red-600 dark:text-red-400 whitespace-nowrap">@ShortageAmount.ToString("N0") @Trip!.GetUnit()</span>
                        </div>
                        <div class="mb-3 flex flex-wrap items-center gap-2">
                            @if (Recommendations.Any())
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200">
                                    ✓ Logged with CCU
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200">
                                    Not yet logged with CCU
                                </span>
                            }
                            @if (FinalDischarge?.ShortageNotifiedAt != null)
                            {
                                <span class="text-xs text-gray-400 dark:text-gray-500">Notified @FinalDischarge.ShortageNotifiedAt.Value.ToString("dd MMM yyyy HH:mm")</span>
                            }
                            else if (MissingCcuRequirements.Count > 0)
                            {
                                <span class="text-xs text-red-500 dark:text-red-400">Missing: @string.Join(", ", MissingCcuRequirements)</span>
                            }
                            else
                            {
                                <span class="text-xs text-gray-400 dark:text-gray-500">Not yet notified</span>
                            }
                        </div>

                        @if (Recommendations.Any())
                        {
                            var current = Recommendations.First();
                            <div class="text-sm space-y-1 rounded-lg bg-blue-50 dark:bg-blue-950/40 border border-blue-100 dark:border-blue-900 p-2.5">
                                <div class="flex justify-between"><span class="text-gray-500 dark:text-gray-400">Recommended</span><span class="font-medium text-gray-900 dark:text-gray-100">@current.RecommendedShortageAmount @Trip!.GetUnit()</span></div>
                                <div class="flex justify-between"><span class="text-gray-500 dark:text-gray-400">CCU Ref</span><span class="font-medium text-gray-900 dark:text-gray-100">@current.CcuReferenceNumber</span></div>
                                <div class="flex justify-between"><span class="text-gray-500 dark:text-gray-400">Received</span><span class="font-medium text-gray-900 dark:text-gray-100">@current.ReceivedDate.ToString("dd MMM yyyy")</span></div>
                                @if (!string.IsNullOrWhiteSpace(current.Remarks))
                                {
                                    <div class="text-gray-600 dark:text-gray-300 text-xs pt-1">@current.Remarks</div>
                                }
                            </div>

                            if (Recommendations.Count > 1)
                            {
                                <details class="text-xs text-gray-500 dark:text-gray-400 mt-2">
                                    <summary class="cursor-pointer">Earlier recommendations (@(Recommendations.Count - 1))</summary>
                                    <ul class="mt-1 space-y-1">
                                        @foreach (var rec in Recommendations.Skip(1))
                                        {
                                            <li class="border-t border-gray-200 dark:border-gray-700 pt-1">
                                                @rec.RecommendedShortageAmount @Trip!.GetUnit() &mdash; @rec.ReceivedDate.ToString("dd MMM yyyy")
                                                @if (!string.IsNullOrWhiteSpace(rec.Remarks))
                                                {
                                                    <div>@rec.Remarks</div>
                                                }
                                            </li>
                                        }
                                    </ul>
                                </details>
                            }
                        }
                        else
                        {
                            <div class="text-gray-500 dark:text-gray-400 italic text-xs py-1">No CCU recommendation recorded yet.</div>
                        }

                        <AuthorizeView Roles="Admin, Master, Supervisor, Manager" Context="auth">
                            <Authorized>
                                <button class="mt-3 w-full px-3 py-2 bg-blue-600 text-white rounded-xl shadow-sm hover:bg-blue-700 text-sm font-medium"
                                        @onclick="() => recommendationModal.Show()">
                                    Record CCU Recommendation
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </div>

                    <RecommendationModal @ref="recommendationModal" TripId="Trip!.Id" OnSave="SaveRecommendation" />
                }

                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5">
                    <h3 class="text-sm font-bold text-gray-800 dark:text-white mb-3">Incidents</h3>
                    @if (Trip?.Incidents != null && Trip.Incidents.Any())
                    {
                        <ul class="divide-y divide-gray-100 dark:divide-gray-700 text-sm max-h-72 overflow-y-auto">
                            @foreach (var req in Trip.Incidents.OrderByDescending(x => x.CreatedAt))
                            {
                                <li class="py-2 first:pt-0 text-gray-900 dark:text-gray-100">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="font-semibold">@req.IncidentType?.Type</span>
                                        <span class="@GetStatusBadgeClass(req.Status) px-1.5 py-0.5 rounded text-xs font-medium">
                                            @StringConverter.ToDescription(req.Status)
                                        </span>
                                        <span class="text-xs text-gray-500 dark:text-gray-400">(@req.CreatedAt.ToString("dd MMM"))</span>
                                    </div>
                                    <div class="text-xs text-gray-600 dark:text-gray-300 mt-0.5">@req.Description</div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-gray-500 dark:text-gray-400 italic text-center py-3 text-sm">No incidents</div>
                    }
                </div>

                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm p-4 sm:p-5">
                    <h3 class="text-sm font-bold text-gray-800 dark:text-white mb-3">Return &amp; Rating</h3>
                    <div class="grid grid-cols-2 gap-x-4 gap-y-4">
                        <DetailBlock Label="Return Date" Value="@Trip?.CloseInfo?.ReturnDateTime?.ToString("dd MMM yyyy")" />
                        <DetailBlock Label="Closed By" Value="@Trip?.ClosedBy?.ToString()" />
                        <DetailBlock Label="Completed By" Value="@(Trip?.Status == TripStatus.Completed ? Trip?.CompletedBy?.ToString() : "N/A")" />
                        @if (!string.IsNullOrEmpty(Trip?.CloseInfo?.SupervisorSignaturePath))
                        {
                            <div>
                                <div class="text-[11px] text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-0.5">Signature</div>
                                <a href="@Trip.CloseInfo.SupervisorSignaturePath" target="_blank" class="text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline" aria-label="View supervisor signature">View</a>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Trip?.CloseInfo?.TripRemark))
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
                            <DetailBlock Label="Trip Remark" Value="@Trip.CloseInfo.TripRemark" />
                        </div>
                    }
                    <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
                        @if (Trip?.CloseInfo.Rating > 0)
                        {
                            <Rating CurrentRating="@Trip!.CloseInfo.Rating" MaxRating="5" Disabled="true" />
                        }
                        else
                        {
                            <span class="text-sm text-gray-400 dark:text-gray-500">Not rated</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid id { get; set; }
    public Trip? Trip { get; set; }
    Product Product { get; set; }
    [CascadingParameter] public Task<AuthenticationState>? authenticationState { get; set; }
    private AuthenticationState? Authentication { get; set; }

    private ConfirmationModal deleteModal = default!;
    private Discharge? editingDischarge;
    private RecommendationModal recommendationModal = default!;
    private FilePreviewModal loadingFilePreview = default!;
    private List<ShortageRecommendation> Recommendations { get; set; } = [];

    private decimal TotalDischarged => Trip?.Discharges?.Sum(d => d.QuantityDischarged) ?? 0;
    private decimal Remaining => (Trip?.LoadingInfo?.Quantity ?? 0) - TotalDischarged;

    // A waybill can cover multiple discharge stops (multi-drop trips); "shortage" only means
    // something once the final drop is done — before that, a partial drop just looks like a
    // shortfall against the full load and isn't one.
    private bool HasFinalDischarge => Trip?.Discharges?.Any(d => d.IsFinalDischarge) ?? false;
    private Discharge? FinalDischarge => Trip?.Discharges?.FirstOrDefault(d => d.IsFinalDischarge);
    private decimal ShortageAmount => HasFinalDischarge ? Remaining : 0;

    // Mirrors ShortageNotificationService.CheckAndNotifyAsync's four requirements, so staff can
    // see exactly what's blocking the CCU notification instead of just "not yet notified".
    private List<string> MissingCcuRequirements
    {
        get
        {
            var missing = new List<string>();
            var hasCalibrationChart = Trip?.Truck?.Files?.Any(f => f.Category == FileCategories.CalibrationChart) ?? false;
            var hasWaybill = FinalDischarge?.Files?.Any(f => f.Category == FileCategories.Waybill) ?? false;
            var hasLoadingUllage = Trip?.LoadingInfo?.Metrics != null && Trip.LoadingInfo.Metrics.Any();
            var hasArrivalUllage = Trip?.Metrics?.Any(m => m.Ullage?.Quantity != null) ?? false;

            if (!hasCalibrationChart) missing.Add("calibration chart");
            if (!hasWaybill) missing.Add("discharge waybill");
            if (!hasLoadingUllage) missing.Add("loading ullage readings");
            if (!hasArrivalUllage) missing.Add("arrival ullage readings");
            return missing;
        }
    }

    private record JourneyStep(string Label, bool Done, string? Date);

    private List<JourneyStep> JourneySteps
    {
        get
        {
            var arrived = Trip?.ArrivalInfo?.ArrivedDepot == true || Trip?.ArrivalInfo?.ArrivedAtStation == true;
            var arrivalDate = Trip?.ArrivalInfo?.ArrivedAtStation == true
                ? Trip?.ArrivalInfo?.StationArrivalDateTime
                : Trip?.ArrivalInfo?.DepotArrivalDateTime;
            var discharges = Trip?.Discharges ?? [];
            var discharged = discharges.Any();
            var dischargeDate = discharged ? discharges.Max(d => d.DischargeStartTime) : null;
            var returned = Trip?.Status is TripStatus.Completed or TripStatus.Closed;

            return
            [
                new("Loading", !string.IsNullOrEmpty(Trip?.LoadingInfo?.WaybillNo), Trip?.LoadingInfo?.LoadingDate?.ToString("dd MMM")),
                new("Transit", arrived, null),
                new("Arrival", arrived, arrivalDate?.ToString("dd MMM")),
                new("Discharge", discharged, dischargeDate?.ToString("dd MMM")),
                new("Return", returned, Trip?.CloseInfo?.ReturnDateTime?.ToString("dd MMM")),
            ];
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        AppState.IsBusy = true;
        try
        {
            Trip = await TripService.GetAsync(id, AppState.GetCancellationToken());
            if (Trip == null)
            {
                ToastService.ShowError("Trip not found.");
                nav.NavigateTo("/trips");
                return;
            }
            Product = Trip!.Truck!.Product!.Value;
            Authentication = await authenticationState!;
            Recommendations = await ShortageRecommendationService.GetForTripAsync(Trip.Id, AppState.GetCancellationToken());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading trip: {ex.Message}");
        }
        finally
        {
            AppState.IsBusy = false;
        }
    }

    private async Task SaveRecommendation(ShortageRecommendation recommendation)
    {
        try
        {
            var success = await ShortageRecommendationService.AddAsync(recommendation, AppState.GetCancellationToken());
            if (success)
            {
                Recommendations = await ShortageRecommendationService.GetForTripAsync(Trip!.Id, AppState.GetCancellationToken());
                ToastService.ShowSuccess("Recommendation recorded!");
            }
            else
            {
                ToastService.ShowWarning("Failed to record recommendation");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Failed to record recommendation");
            Console.WriteLine($"Error saving recommendation: {ex.Message}");
        }
    }
    private void ShowAddDischargeModal()
    {
        editingDischarge = null;
    }

    private void EditDischarge(Discharge discharge)
    {
        editingDischarge = discharge;
    }

    private void HideDischargeModal()
    {
        editingDischarge = null;
        StateHasChanged();
    }

    private async Task SaveDischarge(Discharge discharge)
    {
        try
        {
            bool isEditMode = editingDischarge != null;

            if (isEditMode)
            {
                editingDischarge.TruckArrival = discharge.TruckArrival;
                editingDischarge.DischargeStartTime = discharge.DischargeStartTime;
                editingDischarge.QuantityDischarged = discharge.QuantityDischarged;
                editingDischarge.StationId = discharge.StationId;
                editingDischarge.InvoicedStationId = discharge.InvoicedStationId ?? discharge.StationId;
                editingDischarge.IsFinalDischarge = discharge.IsFinalDischarge;
                editingDischarge.Notes = discharge.Notes;
                editingDischarge.IsSiding = discharge.IsSiding;
                editingDischarge.SidingHours = discharge.SidingHours;
                editingDischarge.InvoicedStation = discharge.InvoicedStation;
            }
            else
            {
                discharge.Id = Guid.NewGuid();
                discharge.TripId = Trip!.Id;
                Trip!.Discharges.Add(discharge);
            }

            ToastService.ShowSuccess(isEditMode ? "Discharge updated!" : "Discharge added!");
            HideDischargeModal();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error: {ex.Message}");
        }
    }


    private async Task DeleteDischarge(Guid dischargeId)
    {
        var discharge = Trip!.Discharges.FirstOrDefault(d => d.Id == dischargeId);
        if (discharge != null)
        {
            Trip!.Discharges.Remove(discharge);
            ToastService.ShowSuccess("Discharge deleted!");
            StateHasChanged();
        }
    }

    private void OnEditTrip() => nav.NavigateTo($"/edit-trip/{Trip?.Id}");
    private void OnBackToTrips() => nav.NavigateTo("/trips");

    private async Task HandleDeleteModalClose(bool confirmed)
    {
        if (!confirmed) return;

        try
        {
            AppState.IsBusy = true;
            await TripService.DeleteAsync(Trip!.Id, AppState.GetCancellationToken());
            ToastService.ShowSuccess("Trip deleted successfully!");
            nav.NavigateTo("/trips");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error deleting trip: {ex.Message}");
        }
        finally
        {
            AppState.IsBusy = false;
        }
    }

    private string GetStatusBadgeClass(TripStatus status)
    {
        return status switch
        {
            TripStatus.Closed => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200 shadow-sm",
            TripStatus.Dispatched => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 shadow-sm",
            TripStatus.Active => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 shadow-sm",
            _ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 shadow-sm",
        };
    }

    private string GetStatusBadgeClass(IncidentStatus status) =>
        status switch
        {
            IncidentStatus.New => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300",
            IncidentStatus.Treated => "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300",
            IncidentStatus.Reported or IncidentStatus.Resolved => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300",
            IncidentStatus.Closed => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300",
            _ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
        };
}

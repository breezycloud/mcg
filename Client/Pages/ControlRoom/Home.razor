@page "/control-room"
@layout ControlRoomLayout
@using ApexCharts
@using Shared.Interfaces.ControlRoom
@using Shared.Models.ControlRoom
@inject IControlRoomService ControlRoomService
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@implements IAsyncDisposable
@attribute [Authorize(Roles = "Admin,Master,Manager,Monitoring,Management")]

<div class="h-screen w-full overflow-hidden flex flex-col p-4 gap-3 box-border">
    <!-- Header -->
    <div class="flex flex-wrap justify-between items-center gap-3 shrink-0">
        <div class="flex items-center gap-3">
            <img src="favicon.png" alt="logo" class="h-8 w-8" />
            <h1 class="text-2xl font-bold tracking-tight">Mutual Commitment Company Control Room</h1>
            <span class="text-sm text-gray-400">@Now.ToString("ddd, MMM d yyyy · HH:mm:ss")</span>
            @if (IsStaging)
            {
                <span class="px-2.5 py-0.5 rounded-full text-xs font-bold uppercase tracking-wide bg-yellow-400 text-yellow-900">Staging</span>
            }
        </div>

        <div class="flex items-center gap-4">
            <!-- Period toggle -->
            <div class="flex rounded-lg overflow-hidden border border-gray-700 text-sm">
                <button @onclick="@(() => SetPeriod(PeriodFilter.ThisMonth))"
                        class="px-3 py-1.5 font-medium @(Period == PeriodFilter.ThisMonth ? "bg-blue-600 text-white" : "bg-gray-900 text-gray-400 hover:bg-gray-800")">
                    This Month
                </button>
                <button @onclick="@(() => SetPeriod(PeriodFilter.AllTime))"
                        class="px-3 py-1.5 font-medium @(Period == PeriodFilter.AllTime ? "bg-blue-600 text-white" : "bg-gray-900 text-gray-400 hover:bg-gray-800")">
                    All Time
                </button>
            </div>

            <div class="text-right text-xs text-gray-400">
                <div>Updated @LastUpdated.ToString("HH:mm:ss")</div>
                <div class="@(IsLoading ? "text-yellow-400" : IsPushConnected ? "text-green-400" : "text-gray-500")">
                    @(IsLoading ? "● Refreshing" : IsPushConnected ? "● Live" : "● Polling")
                </div>
            </div>
        </div>
    </div>

    @if (Metrics is null)
    {
        <div class="flex-1 flex justify-center items-center">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-500"></div>
        </div>
    }
    else
    {
        <!-- KPI cards -->
        <div class="grid grid-cols-4 lg:grid-cols-8 gap-2 shrink-0">
            <KpiCard Label="Deployed Trucks" SubValue="@($"{Metrics.TrucksLoadedInPeriod} loaded · {Metrics.TruckUtilizationRate:F0}% util.")"
                     IconPath="@IconTruck" IconColorClass="text-blue-400" IconBgClass="bg-blue-500/15">
                <ValueContent><AnimatedNumber Value="@Metrics.TotalDeployedTrucks" />/<AnimatedNumber Value="@Metrics.TotalTrucksInFleet" /></ValueContent>
            </KpiCard>
            <KpiCard Label="Active Trips" SubValue="@($"{Metrics.TripsToday} today")"
                     IconPath="@IconMapPin" IconColorClass="text-indigo-400" IconBgClass="bg-indigo-500/15">
                <ValueContent><AnimatedNumber Value="@Metrics.ActiveTrips" /></ValueContent>
            </KpiCard>
            <KpiCard Label="@CompletionLabel" SubValue="@($"{Metrics.TripsInPeriod} trips")"
                     IconPath="@IconCheckCircle" IconColorClass="text-emerald-400" IconBgClass="bg-emerald-500/15">
                <ValueContent><AnimatedNumber Value="@Metrics.TripCompletionRate" Decimals="0" Suffix="%" /></ValueContent>
            </KpiCard>
            <KpiCard Label="Avg Duration" SubValue="@PeriodLabel"
                     IconPath="@IconClock" IconColorClass="text-sky-400" IconBgClass="bg-sky-500/15">
                <ValueContent><AnimatedNumber Value="@Metrics.AvgTripDurationDays" Decimals="1" Suffix="d" /></ValueContent>
            </KpiCard>
            <KpiCard Label="Shortage Rate" Accent="@(Metrics.ShortageRate > 20 ? "text-red-400" : "text-white")" SubValue="@PeriodLabel"
                     IconPath="@IconTrendingDown" IconColorClass="text-red-400" IconBgClass="bg-red-500/15">
                <ValueContent>
                    <span class="inline-flex items-center gap-1">
                        <AnimatedNumber Value="@Metrics.ShortageRate" Decimals="1" Suffix="%" />
                        @if (Metrics.ShortageRate > 20)
                        {
                            <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <span class="sr-only">— above the 20% threshold</span>
                        }
                    </span>
                </ValueContent>
            </KpiCard>
            <KpiCard Label="On-Time Delivery" Accent="@(Metrics.OnTimeDeliveryRate < 70 ? "text-red-400" : "text-white")" SubValue="@PeriodLabel"
                     IconPath="@IconCalendarCheck" IconColorClass="text-teal-400" IconBgClass="bg-teal-500/15">
                <ValueContent>
                    <span class="inline-flex items-center gap-1">
                        <AnimatedNumber Value="@Metrics.OnTimeDeliveryRate" Decimals="0" Suffix="%" />
                        @if (Metrics.OnTimeDeliveryRate < 70)
                        {
                            <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            <span class="sr-only">— below the 70% threshold</span>
                        }
                    </span>
                </ValueContent>
            </KpiCard>
            <KpiCard Label="Open Incidents" SubValue="@($"{Metrics.IncidentRate:F1}% rate")" Accent="@(Metrics.OpenIncidents > 0 ? "text-orange-400" : "text-white")"
                     IconPath="@IconWarningTriangle" IconColorClass="text-orange-400" IconBgClass="bg-orange-500/15">
                <ValueContent><AnimatedNumber Value="@Metrics.OpenIncidents" /></ValueContent>
            </KpiCard>
            <KpiCard Label="Open Service Req." SubValue="@($"{Metrics.AvgMaintenanceTatDays:F1}d avg TAT")"
                     IconPath="@IconWrench" IconColorClass="text-violet-400" IconBgClass="bg-violet-500/15">
                <ValueContent><AnimatedNumber Value="@Metrics.OpenServiceRequests" /></ValueContent>
            </KpiCard>
        </div>

        <!-- Main content: three equal columns, each capped so nothing needs to scroll -->
        <div class="flex-1 min-h-0 grid grid-cols-3 gap-3">
            <!-- Product breakdown (trip count) + quantity loaded, stacked in one column -->
            <div class="flex flex-col gap-3 h-full min-h-0">
                <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex-1 min-h-0 flex flex-col overflow-hidden">
                    <h2 class="text-sm font-semibold mb-2 text-gray-300">Product Breakdown &middot; @PeriodLabel</h2>
                    @if (ProductBreakdown.Count == 0)
                    {
                        <p class="text-gray-500 text-sm">No trips in this period.</p>
                    }
                    <!-- Kept mounted even with zero rows (just hidden) instead of being conditionally
                         removed — unmounting/remounting the chart on every toggle invalidates its
                         component reference, and calling UpdateSeriesAsync() on the stale reference
                         in LoadDataAsync throws. -->
                    <div class="flex-1 min-h-0 @(ProductBreakdown.Count == 0 ? "hidden" : "")">
                        <ApexChart @ref="chart" TItem="ProductBreakdownDto" Options="chartOptions" Height="220">
                            <ApexPointSeries TItem="ProductBreakdownDto"
                                             Items="ProductBreakdown"
                                             SeriesType="SeriesType.Bar"
                                             Name="Trips"
                                             XValue="@(e => e.Product)"
                                             YValue="@(e => (decimal)e.TripCount)"
                                             ShowDataLabels="true" />
                        </ApexChart>
                    </div>
                </div>

                <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex-1 min-h-0 flex flex-col overflow-hidden">
                    <h2 class="text-sm font-semibold mb-2 text-gray-300">Quantity Loaded by Product &middot; @PeriodLabel</h2>
                    @if (ProductBreakdown.Count == 0)
                    {
                        <p class="text-gray-500 text-sm">No trips in this period.</p>
                    }
                    else
                    {
                        <div class="flex-1 min-h-0 overflow-y-auto space-y-1.5">
                            @foreach (var entry in QuantityByProduct)
                            {
                                <!-- @key: QuantityByProduct is sorted by quantity, so rank can reorder between
                                     refreshes — without a stable key, Blazor would reuse a row's AnimatedNumber
                                     for a different product and animate between two unrelated values. -->
                                <div @key="entry.Product" class="flex items-center justify-between text-xs py-1 border-b border-gray-800/60 last:border-0">
                                    <div class="flex items-center gap-2 min-w-0">
                                        <span class="h-2.5 w-2.5 rounded-full flex-shrink-0 @GetProductColorClass(entry.Product)" style="@GetProductColorStyle(entry.Product)"></span>
                                        <span class="text-gray-300 font-medium truncate">@FormatProduct(entry.Product)</span>
                                        <span class="text-gray-500 flex-shrink-0">(@entry.TripCount trips)</span>
                                    </div>
                                    <span class="font-semibold text-white flex-shrink-0 pl-2">
                                        <AnimatedNumber Value="@entry.TotalQuantity" Suffix="@($" {GetUnitForProduct(entry.Product)}")" />
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Product leaders + laggards, stacked in one column -->
            <div class="flex flex-col gap-3 h-full min-h-0">
                <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex-1 min-h-0 flex flex-col overflow-hidden">
                    <h2 class="text-sm font-semibold mb-2 text-gray-300">Product Leaders &middot; @PeriodLabel</h2>
                    @if (ProductLeaders.Count == 0)
                    {
                        <p class="text-gray-500 text-sm">No trips in this period.</p>
                    }
                    else
                    {
                        <div class="flex-1 min-h-0 overflow-x-auto overflow-y-hidden">
                            <table class="w-full text-xs text-left">
                                <thead class="uppercase text-gray-500 border-b border-gray-800">
                                    <tr>
                                        <th class="py-1.5 pr-2">Product</th>
                                        <th class="py-1.5 pr-2">Truck</th>
                                        <th class="py-1.5 pr-2">Trips</th>
                                        <th class="py-1.5 pr-2">Volume</th>
                                        <th class="py-1.5 pr-2">Shortage</th>
                                        <th class="py-1.5 pr-2">Avg Days</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in ProductLeaders)
                                    {
                                        <tr class="border-b border-gray-800/60 last:border-0">
                                            <td class="py-1.5 pr-2 font-medium">@FormatProduct(entry.Product)</td>
                                            <td class="py-1.5 pr-2">@entry.TruckNo</td>
                                            <td class="py-1.5 pr-2">@entry.TripCount</td>
                                            <td class="py-1.5 pr-2">@entry.TotalQuantityDispatched.ToString("N0")</td>
                                            <td class="py-1.5 pr-2 @(entry.ShortageRate > 20 ? "text-red-400" : "")">@entry.ShortageRate.ToString("F1")%</td>
                                            <td class="py-1.5 pr-2">@entry.AvgTripDurationDays.ToString("F1")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex-1 min-h-0 flex flex-col overflow-hidden">
                    <h2 class="text-sm font-semibold mb-2 text-gray-300">Product Laggards &middot; @PeriodLabel</h2>
                    @if (ProductLaggards.Count == 0)
                    {
                        <p class="text-gray-500 text-sm">No trips in this period.</p>
                    }
                    else
                    {
                        <div class="flex-1 min-h-0 overflow-x-auto overflow-y-hidden">
                            <table class="w-full text-xs text-left">
                                <thead class="uppercase text-gray-500 border-b border-gray-800">
                                    <tr>
                                        <th class="py-1.5 pr-2">Product</th>
                                        <th class="py-1.5 pr-2">Truck</th>
                                        <th class="py-1.5 pr-2">Trips</th>
                                        <th class="py-1.5 pr-2">Volume</th>
                                        <th class="py-1.5 pr-2">Shortage</th>
                                        <th class="py-1.5 pr-2">Avg Days</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in ProductLaggards)
                                    {
                                        <tr class="border-b border-gray-800/60 last:border-0">
                                            <td class="py-1.5 pr-2 font-medium">@FormatProduct(entry.Product)</td>
                                            <td class="py-1.5 pr-2">@entry.TruckNo</td>
                                            <td class="py-1.5 pr-2">@entry.TripCount</td>
                                            <td class="py-1.5 pr-2">@entry.TotalQuantityDispatched.ToString("N0")</td>
                                            <td class="py-1.5 pr-2 @(entry.ShortageRate > 20 ? "text-red-400" : "")">@entry.ShortageRate.ToString("F1")%</td>
                                            <td class="py-1.5 pr-2">@entry.AvgTripDurationDays.ToString("F1")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent incidents + shortage breakdown, stacked in one column -->
            <div class="flex flex-col gap-3 h-full min-h-0">
                <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex-1 min-h-0 flex flex-col overflow-hidden">
                    <h2 class="text-sm font-semibold mb-2 text-gray-300">Recent Incidents</h2>
                    @if (RecentIncidents.Count == 0)
                    {
                        <p class="text-gray-500 text-sm">No recent incidents.</p>
                    }
                    else
                    {
                        <ul class="flex-1 min-h-0 overflow-hidden space-y-2">
                            @foreach (var incident in RecentIncidents)
                            {
                                <li @key="incident.Id" class="flex justify-between items-start border-b border-gray-800 pb-2 last:border-0 text-xs rounded transition-colors duration-1000 @(NewIncidentIds.Contains(incident.Id) ? "bg-blue-500/20 ring-1 ring-blue-500/40 -mx-1 px-1" : "")">
                                    <div>
                                        <div class="font-medium flex items-center gap-1.5">
                                            @incident.TruckNo
                                            @if (NewIncidentIds.Contains(incident.Id))
                                            {
                                                <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                                            }
                                        </div>
                                        <div class="text-gray-400">@incident.IncidentType</div>
                                    </div>
                                    <div class="text-right">
                                        <div class="px-2 py-0.5 rounded-full bg-gray-800 inline-block">@incident.Status</div>
                                        <div class="text-gray-500 mt-1">@incident.CreatedAt.LocalDateTime.ToString("MMM d, HH:mm")</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex-1 min-h-0 flex flex-col overflow-hidden">
                    <div class="flex items-center justify-between mb-2">
                        <h2 class="text-sm font-semibold text-gray-300">Shortage by Product &middot; @PeriodLabel</h2>
                        @if (ShortageBreakdown.Count > 0)
                        {
                            <span class="text-xs text-gray-500">Total: <span class="font-semibold text-white">@TotalShortageUnits.ToString("N0")</span></span>
                        }
                    </div>
                    @if (ShortageBreakdown.Count == 0)
                    {
                        <p class="text-gray-500 text-sm">No shortages in this period.</p>
                    }
                    <!-- Same always-mounted pattern as the Product Breakdown chart above — see the
                         comment on that chart for why it must not be conditionally unmounted. -->
                    <div class="flex-1 min-h-0 @(ShortageBreakdown.Count == 0 ? "hidden" : "")">
                        <ApexChart @ref="shortageChart" TItem="ProductBreakdownDto" Options="shortageChartOptions" Height="220">
                            <ApexPointSeries TItem="ProductBreakdownDto"
                                             Items="ShortageBreakdown"
                                             SeriesType="SeriesType.Pie"
                                             Name="Shortage"
                                             XValue="@(e => FormatProduct(e.Product))"
                                             YValue="@(e => e.TotalShortageQuantity)"
                                             ShowDataLabels="true" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private enum PeriodFilter { ThisMonth, AllTime }

    // Push (SignalR) is now the primary refresh path — Trip/Discharge/Incident/ServiceRequest
    // saves broadcast instantly (with a ~2-5s server+client debounce). This poll is only a
    // fallback for a dropped/missed connection, so it can be slow.
    private const int RefreshIntervalSeconds = 180;
    private const int IncidentsCount = 6;

    // Heroicons (solid, 24x24) — one per KPI card, picked for what each metric actually means
    // rather than reusing a generic truck/chart glyph everywhere.
    private const string IconTruck = "<path d=\"M13 7h6l2 4m-8-4v8m0-8V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v9h2m8 0H9m4 0h2m4 0h2v-4m0 0h-5m3.5 5.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm-10 0a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />"; // Deployed Trucks
    private const string IconMapPin = "<path fill-rule=\"evenodd\" d=\"M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z\" clip-rule=\"evenodd\" />"; // Active Trips
    private const string IconCheckCircle = "<path fill-rule=\"evenodd\" d=\"M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z\" clip-rule=\"evenodd\" />"; // Completion Rate
    private const string IconClock = "<path fill-rule=\"evenodd\" d=\"M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z\" clip-rule=\"evenodd\" />"; // Avg Duration
    private const string IconTrendingDown = "<path fill-rule=\"evenodd\" d=\"M1.72 5.47a.75.75 0 011.06 0L9 11.69l3.756-3.756a.75.75 0 01.985-.066 12.698 12.698 0 014.575 6.832l.308 1.149 2.277-3.943a.75.75 0 111.299.75l-3.182 5.51a.75.75 0 01-1.025.275l-5.511-3.181a.75.75 0 01.75-1.3l3.943 2.277-.309-1.149a11.197 11.197 0 00-3.876-5.815L9.53 13.19a.75.75 0 01-1.06 0L1.72 6.53a.75.75 0 010-1.061z\" clip-rule=\"evenodd\" />"; // Shortage Rate
    private const string IconCalendarCheck = "<path fill-rule=\"evenodd\" d=\"M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z\" clip-rule=\"evenodd\" />"; // On-Time Delivery
    private const string IconWarningTriangle = "<path fill-rule=\"evenodd\" d=\"M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003zM12 8.25a.75.75 0 01.75.75v3.75a.75.75 0 01-1.5 0V9a.75.75 0 01.75-.75zm0 8.25a.75.75 0 100-1.5.75.75 0 000 1.5z\" clip-rule=\"evenodd\" />"; // Open Incidents
    private const string IconWrench = "<path fill-rule=\"evenodd\" d=\"M12 6.75a5.25 5.25 0 016.775-5.025.75.75 0 01.313 1.248l-3.32 3.319c.063.475.276.934.641 1.299.365.365.824.578 1.3.64l3.318-3.319a.75.75 0 011.248.313 5.25 5.25 0 01-5.472 6.756c-1.018-.086-1.87.1-2.309.634L7.344 21.3A3.298 3.298 0 112.7 16.657l8.684-7.151c.533-.44.72-1.291.634-2.309A5.342 5.342 0 0112 6.75zM4.117 19.125a.75.75 0 01.75-.75h.008a.75.75 0 01.75.75v.008a.75.75 0 01-.75.75h-.008a.75.75 0 01-.75-.75v-.008z\" clip-rule=\"evenodd\" />"; // Open Service Requests

    private PeriodFilter Period = PeriodFilter.ThisMonth;

    private ControlRoomMetricsDto? Metrics;
    private List<ProductBreakdownDto> ProductBreakdown = [];
    private List<ProductLeaderDto> ProductLeaders = [];
    private List<ProductLeaderDto> ProductLaggards = [];
    private List<RecentIncidentDto> RecentIncidents = [];

    // Drives the "just arrived" highlight on Recent Incidents. Populated by diffing each fetch
    // against the previous one — null until the first successful fetch so the initial page load
    // doesn't flag every incident already on screen as "new".
    private HashSet<Guid>? _knownIncidentIds;
    private HashSet<Guid> NewIncidentIds { get; set; } = [];
    private CancellationTokenSource? _newIncidentHighlightCts;

    private ApexChart<ProductBreakdownDto>? chart;
    private ApexChartOptions<ProductBreakdownDto> chartOptions = new();

    private ApexChart<ProductBreakdownDto>? shortageChart;
    private ApexChartOptions<ProductBreakdownDto> shortageChartOptions = new();
    private List<ProductBreakdownDto> ShortageBreakdown => ProductBreakdown.Where(p => p.TotalShortageQuantity > 0).ToList();
    // Sums across products with different units (LTR/KG/SCM) — an approximate cumulative figure,
    // same basis the pie's own slice proportions are already computed on.
    private decimal TotalShortageUnits => ShortageBreakdown.Sum(p => p.TotalShortageQuantity);
    private List<ProductBreakdownDto> QuantityByProduct => ProductBreakdown.OrderByDescending(p => p.TotalQuantity).ToList();

    private bool IsLoading;
    private bool IsPushConnected;
    private HubConnection? hubConnection;
    private DateTime LastUpdated = DateTime.Now;
    private DateTime Now = DateTime.Now;
    private bool IsStaging => new Uri(NavigationManager.BaseUri).Host.Contains("staging");

    private string PeriodLabel => Period == PeriodFilter.ThisMonth ? "This Month" : "All Time";
    private string CompletionLabel => "Completion Rate";

    private DateOnly? StartDateParam => Period == PeriodFilter.ThisMonth
        ? new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1)
        : null;

    private static string FormatProduct(string product) => product switch
    {
        "CngAbuja" => "CNG-Abuja",
        "CngLagos" => "CNG-Lagos",
        _ => product
    };

    // Matches Dashboard's ProductShipments.razor so the same product reads the same color everywhere.
    private static string GetProductColorClass(string product) => product switch
    {
        "PMS" => "bg-blue-500",
        "ATK" => "bg-black",
        "AGO" => "", // blue base + yellow top stripe applied via inline style instead
        "LPG" => "bg-blue-900",
        "CngLagos" => "", // purple base + white top stripe applied via inline style instead
        "CngAbuja" => "bg-purple-500",
        _ => "bg-gray-500"
    };

    private static string GetProductColorStyle(string product) => product switch
    {
        "AGO" => TopStripeGradient(baseColor: "#0ea5e9", stripeColor: "#eab308"),
        "CngLagos" => TopStripeGradient(baseColor: "#a855f7", stripeColor: "#eab308"),
        _ => ""
    };

    private static string TopStripeGradient(string baseColor, string stripeColor)
        => $"background: linear-gradient(to bottom, {stripeColor} 0%, {stripeColor} 30%, {baseColor} 30%, {baseColor} 100%);";

    private static string GetUnitForProduct(string product) => product switch
    {
        "CngAbuja" or "CngLagos" => "SCM",
        "LPG" => "KG",
        _ => "LTR"
    };

    private PeriodicTimer? timer;
    private PeriodicTimer? clockTimer;
    private CancellationTokenSource? cts;

    protected override async Task OnInitializedAsync()
    {
        chartOptions = new ApexChartOptions<ProductBreakdownDto>
        {
            Theme = new Theme { Mode = Mode.Dark },
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false, ColumnWidth = "55%", BorderRadius = 4 } },
            Colors = ["#3b82f6"],
            Grid = new Grid { BorderColor = "#374151", StrokeDashArray = 4 },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } }
        };

        shortageChartOptions = new ApexChartOptions<ProductBreakdownDto>
        {
            Theme = new Theme { Mode = Mode.Dark },
            Colors = ["#22c55e", "#f59e0b", "#ef4444", "#3b82f6", "#a855f7", "#eab308"],
            Legend = new Legend { Position = LegendPosition.Bottom },
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            // Pie/donut dataLabels' `val` is already the slice's % of the whole — pull the raw
            // unit total back out of series/seriesIndex so each slice shows both.
            DataLabels = new DataLabels
            {
                Enabled = true,
                Style = new DataLabelsStyle { FontSize = "10px" },
                Formatter = "function (val, opts) { var raw = opts.w.config.series[opts.seriesIndex]; return raw.toLocaleString() + ' (' + val.toFixed(1) + '%)'; }"
            }
        };

        await LoadDataAsync();

        AppState.DashboardDataChanged += OnDashboardDataChanged;
        await InitializeSignalR();

        cts = new CancellationTokenSource();
        _ = RefreshLoopAsync(cts.Token);
        _ = ClockLoopAsync(cts.Token);
    }

    private async Task InitializeSignalR()
    {
        // Page-scoped connection, same pattern as Dashboards/Home.razor — the hub is mapped on
        // the Api, not the Client, and each page that wants push updates opens its own connection.
        var apiBaseAddress = new Client.Handlers.Constants(NavigationManager, Configuration).BaseAddress();
        var hubUrl = new Uri(new Uri(apiBaseAddress), "/hubs/dashboard");

        hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string>("DashboardDataChanged", entityType => AppState.OnDashboardDataChanged(entityType));
        hubConnection.Reconnected += _ => { IsPushConnected = true; return InvokeAsync(StateHasChanged); };
        hubConnection.Closed += _ => { IsPushConnected = false; return InvokeAsync(StateHasChanged); };

        try
        {
            await hubConnection.StartAsync();
            IsPushConnected = true;
        }
        catch
        {
            IsPushConnected = false;
        }
    }

    // Control Room's numbers are aggregates over the whole fleet/period, so unlike the per-widget
    // Dashboard components, every entity type this event can carry (Trip, Discharge, Incident,
    // ServiceRequest) is potentially relevant to something on this page — just reload everything
    // rather than filtering by entityType.
    private async void OnDashboardDataChanged(object? sender, string entityType)
    {
        await LoadDataAsync();
    }

    private async Task ClockLoopAsync(CancellationToken token)
    {
        clockTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await clockTimer.WaitForNextTickAsync(token))
            {
                Now = DateTime.Now;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on Dispose — the page is navigating away.
        }
    }

    private async Task SetPeriod(PeriodFilter period)
    {
        if (Period == period)
            return;

        Period = period;
        await LoadDataAsync();
    }

    private async Task RefreshLoopAsync(CancellationToken token)
    {
        timer = new PeriodicTimer(TimeSpan.FromSeconds(RefreshIntervalSeconds));
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                await LoadDataAsync();
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on Dispose — the page is navigating away.
        }
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var startDate = StartDateParam;
            Metrics = await ControlRoomService.GetMetricsAsync(startDate);
            ProductBreakdown = await ControlRoomService.GetProductBreakdownAsync(startDate);
            ProductLeaders = await ControlRoomService.GetProductLeadersAsync(startDate);
            ProductLaggards = await ControlRoomService.GetProductLaggardsAsync(startDate);
            RecentIncidents = await ControlRoomService.GetRecentIncidentsAsync(IncidentsCount);
            UpdateNewIncidentHighlights(RecentIncidents);
            LastUpdated = DateTime.Now;
        }
        catch (Exception ex)
        {
            // Swallow here rather than letting it bubble — an uncaught exception here would kill
            // the fallback poll loop permanently (it only catches OperationCanceledException),
            // and this method is also invoked directly from the SignalR push handler, so a
            // control-room screen needs to keep working indefinitely even after a transient
            // network/auth blip. Stale data stays on screen until the next successful call.
            ToastService.ShowError($"Control room refresh failed: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            // Render first so the ApexPointSeries child picks up the new ProductBreakdown via its
            // Items parameter — calling UpdateSeriesAsync() before this render pushes the chart's
            // *previous* series into the JS chart, which visually lags the toggle by one click.
            await InvokeAsync(StateHasChanged);
            if (ProductBreakdown.Count > 0 && chart is not null)
                await chart.UpdateSeriesAsync();
            if (ShortageBreakdown.Count > 0 && shortageChart is not null)
            {
                // Pie/donut slice labels live in Options.Labels, not the series values —
                // UpdateSeriesAsync() alone doesn't refresh them, so when the product count
                // changes between toggles the newly-added slices fall back to "series-N".
                // UpdateOptionsAsync() forces the labels to be recomputed from the current
                // ShortageBreakdown before the series values are pushed.
                await shortageChart.UpdateOptionsAsync(true, true, true);
                await shortageChart.UpdateSeriesAsync();
            }
        }
    }

    // Diffs the freshly-fetched incident list against the previous one so newly-arrived incidents
    // can get a "just arrived" highlight instead of the whole list silently reordering. Skipped on
    // the very first load (_knownIncidentIds is null) — otherwise every incident already on screen
    // would flash as "new" the moment the page opens.
    private void UpdateNewIncidentHighlights(List<RecentIncidentDto> incidents)
    {
        var currentIds = incidents.Select(i => i.Id).ToHashSet();

        if (_knownIncidentIds is not null)
        {
            var newIds = currentIds.Except(_knownIncidentIds).ToHashSet();
            if (newIds.Count > 0)
            {
                NewIncidentIds = newIds;
                _newIncidentHighlightCts?.Cancel();
                _newIncidentHighlightCts = new CancellationTokenSource();
                _ = ClearIncidentHighlightAfterDelayAsync(_newIncidentHighlightCts.Token);
            }
        }

        _knownIncidentIds = currentIds;
    }

    private async Task ClearIncidentHighlightAfterDelayAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), token);
            NewIncidentIds = [];
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            // Superseded by a newer batch of incidents before this delay elapsed — that batch's
            // own timer will clear the highlight instead.
        }
    }

    public async ValueTask DisposeAsync()
    {
        AppState.DashboardDataChanged -= OnDashboardDataChanged;
        cts?.Cancel();
        cts?.Dispose();
        timer?.Dispose();
        clockTimer?.Dispose();
        _newIncidentHighlightCts?.Cancel();
        _newIncidentHighlightCts?.Dispose();

        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}

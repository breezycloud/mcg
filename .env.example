# Copy to .env (gitignored) and fill in real values before running `docker compose up`.
# These are consumed by docker-compose.yml — see comments there for how each is used.

# Local-only Postgres/RabbitMQ container credentials — pick any values, these
# containers are created fresh by docker-compose and don't need to match staging/prod.
POSTGRES_PASSWORD=
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# Real application secrets — get these from an existing team member or your
# secrets manager. Never commit real values for these.
APP_KEY=
EXTERNAL_API_KEY=

# Optional — leave blank to skip sending real email locally.
# BREVO_MAKULLI = Brevo API key, BREVO_SMTP_KEY = Brevo SMTP key (login = BREVO_EMAIL)
BREVO_MAKULLI=
BREVO_EMAIL=
BREVO_SMTP_KEY=
